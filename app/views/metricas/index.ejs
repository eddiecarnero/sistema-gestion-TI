<div class="top-bar">
  <div>
    <h1 class="page-title">Métricas de Rendimiento de Personal</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Indicadores y estadísticas de desempeño de técnicos y practicantes</p>
  </div>
</div>

<div class="clay-card">
  <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 25px; color: var(--primary);"><i class="fa-solid fa-chart-bar" style="margin-right: 8px;"></i>Tabla Comparativa de Desempeño</h2>
  
  <div class="table-responsive" style="margin-bottom: 0;">
    <table class="clay-table">
      <thead>
        <tr>
          <th>Técnico</th>
          <th>Rango / Rol</th>
          <th style="text-align: center;">Incidencias Asignadas</th>
          <th style="text-align: center;">Incidencias Resueltas</th>
          <th style="text-align: center;">Incidencias Pendientes</th>
          <th style="text-align: center;">Total Horas Invertidas</th>
          <th style="text-align: center;">Promedio Horas / Incidencia</th>
        </tr>
      </thead>
      <tbody>
        <% if (metricas && metricas.length > 0) { %>
          <% metricas.forEach(m => { %>
            <tr>
              <td style="font-weight: 800; color: #fff;"><%= m.nombres %> <%= m.apellidos %></td>
              <td style="text-transform: capitalize;"><%= m.rango %></td>
              <td style="text-align: center; font-weight: 700;"><%= m.total_incidencias_asignadas %></td>
              <td style="text-align: center; color: var(--accent); font-weight: 700;"><%= m.total_incidencias_resueltas %></td>
              <td style="text-align: center; color: var(--warning); font-weight: 700;"><%= m.incidencias_pendientes %></td>
              <td style="text-align: center;"><%= parseFloat(m.total_horas_invertidas).toFixed(2) %> h</td>
              <td style="text-align: center; font-weight: 800; color: var(--primary);">
                <%= parseFloat(m.promedio_horas_por_incidencia).toFixed(2) %> h
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" style="text-align: center; color: var(--text-secondary); padding: 20px 0;">No se encontraron datos de métricas disponibles.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
  
  <!-- Resumen de Carga de Trabajo -->
  <div class="clay-card">
    <h2 style="font-size: 18px; font-weight: 800; margin-bottom: 20px; color: var(--secondary);"><i class="fa-solid fa-list-check" style="margin-right: 8px;"></i>Resumen de Carga Actual</h2>
    <p style="color: var(--text-secondary); margin-bottom: 15px; font-weight: 600; line-height: 1.5;">El siguiente listado resume a los miembros del personal con mayor carga de tickets pendientes (carga de trabajo en curso):</p>
    
    <% if (metricas && metricas.length > 0) { %>
      <div style="display: flex; flex-direction: column; gap: 15px;">
        <% metricas.forEach(m => { %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; background-color: var(--bg-input); border-radius: 14px; border: 1px solid var(--border);">
            <span style="font-weight: 700;"><%= m.nombres %> <%= m.apellidos %></span>
            <span class="badge badge-<%= m.incidencias_pendientes > 2 ? 'prioridad-alta' : (m.incidencias_pendientes > 0 ? 'pendiente' : 'resuelta') %>" style="font-size: 13px;">
              <%= m.incidencias_pendientes %> tickets
            </span>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color: var(--text-muted);">No hay información disponible.</p>
    <% } %>
  </div>

  <!-- Eficiencia de Resolución -->
  <div class="clay-card">
    <h2 style="font-size: 18px; font-weight: 800; margin-bottom: 20px; color: var(--accent);"><i class="fa-solid fa-gauge-high" style="margin-right: 8px;"></i>Eficiencia de Resolución</h2>
    <p style="color: var(--text-secondary); margin-bottom: 15px; font-weight: 600; line-height: 1.5;">Tiempo promedio en horas invertido por ticket resuelto. Un tiempo menor indica una resolución más ágil de las fallas:</p>
    
    <% if (metricas && metricas.length > 0) { %>
      <div style="display: flex; flex-direction: column; gap: 15px;">
        <% metricas.forEach(m => { %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; background-color: var(--bg-input); border-radius: 14px; border: 1px solid var(--border);">
            <span style="font-weight: 700;"><%= m.nombres %> <%= m.apellidos %></span>
            <span style="font-weight: 800; color: var(--primary);"><%= parseFloat(m.promedio_horas_por_incidencia).toFixed(1) %> horas/ticket</span>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color: var(--text-muted);">No hay información disponible.</p>
    <% } %>
  </div>

</div>
