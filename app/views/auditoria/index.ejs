<div class="top-bar">
  <div>
    <h1 class="page-title">Bitácora de Auditoría</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Monitoreo de inserciones y modificaciones de datos en el sistema (Solo Lectura)</p>
  </div>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>Log ID</th>
        <th>Responsable Técnico</th>
        <th>Tabla</th>
        <th>Operación</th>
        <th>Valores Nuevos</th>
        <th>Valores Anteriores</th>
        <th>Fecha & Hora</th>
      </tr>
    </thead>
    <tbody>
      <% if (logs && logs.length > 0) { %>
        <% logs.forEach(log => { %>
          <tr>
            <td>#<%= log.id_auditoria_tecnico %></td>
            <td style="font-weight: 700; color: #fff;"><%= log.tecnico_nombres %> <%= log.tecnico_apellidos %></td>
            <td style="text-transform: capitalize;"><%= log.tabla_afectada %></td>
            <td>
              <span class="badge badge-<%= log.permiso_realizado === 'INSERT' ? 'resuelta' : 'en_proceso' %>">
                <%= log.permiso_realizado %>
              </span>
            </td>
            <td>
              <% if (log.valor_agregado) { %>
                <details style="cursor: pointer; font-size: 13px;">
                  <summary style="font-weight: 700; color: var(--primary);">Ver JSON</summary>
                  <pre style="background: var(--bg-input); padding: 10px; border-radius: 8px; border: 1px solid var(--border); margin-top: 5px; font-family: monospace; overflow-x: auto; max-width: 300px;"><%= JSON.stringify(log.valor_agregado, null, 2) %></pre>
                </details>
              <% } else { %>
                <span style="color: var(--text-muted);">N/A</span>
              <% } %>
            </td>
            <td>
              <% if (log.valor_anterior) { %>
                <details style="cursor: pointer; font-size: 13px;">
                  <summary style="font-weight: 700; color: var(--warning);">Ver JSON</summary>
                  <pre style="background: var(--bg-input); padding: 10px; border-radius: 8px; border: 1px solid var(--border); margin-top: 5px; font-family: monospace; overflow-x: auto; max-width: 300px;"><%= JSON.stringify(log.valor_anterior, null, 2) %></pre>
                </details>
              <% } else { %>
                <span style="color: var(--text-muted);">N/A (Inserción)</span>
              <% } %>
            </td>
            <td style="font-size: 14px;"><%= new Date(log.fecha_realizado).toLocaleString('es-ES') %></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="7" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No hay logs de auditoría registrados.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
