<div class="top-bar">
  <div>
    <h1 class="page-title">Editar Equipo: <%= equipo.codigo_inventario %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Actualice los datos generales del dispositivo</p>
  </div>
  <div>
    <a href="/equipos/<%= equipo.id_equipo %>" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Ficha
    </a>
  </div>
</div>

<div style="max-width: 700px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/equipos/<%= equipo.id_equipo %>/editar" method="POST">
      <div class="form-group">
        <label for="codigo_inventario" class="form-label">Código de Inventario</label>
        <input type="text" id="codigo_inventario" name="codigo_inventario" class="clay-input" value="<%= equipo.codigo_inventario %>" required>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="tipo" class="form-label">Tipo de Equipo</label>
          <select id="tipo" name="tipo" class="clay-select" required>
            <option value="laptop" <%= equipo.tipo === 'laptop' ? 'selected' : '' %>>Laptop</option>
            <option value="pc_escritorio" <%= equipo.tipo === 'pc_escritorio' ? 'selected' : '' %>>PC Escritorio</option>
            <option value="proyector" <%= equipo.tipo === 'proyector' ? 'selected' : '' %>>Proyector</option>
            <option value="teclado" <%= equipo.tipo === 'teclado' ? 'selected' : '' %>>Teclado</option>
            <option value="mouse" <%= equipo.tipo === 'mouse' ? 'selected' : '' %>>Mouse</option>
            <option value="monitor" <%= equipo.tipo === 'monitor' ? 'selected' : '' %>>Monitor</option>
            <option value="otro" <%= equipo.tipo === 'otro' ? 'selected' : '' %>>Otro</option>
          </select>
        </div>

        <div class="form-group">
          <label for="tipo_origen" class="form-label">Origen</label>
          <select id="tipo_origen" name="tipo_origen" class="clay-select" required>
            <option value="comprado_ensamblado" <%= equipo.tipo_origen === 'comprado_ensamblado' ? 'selected' : '' %>>Comprado Ensamblado</option>
            <option value="ensamblado_facultad" <%= equipo.tipo_origen === 'ensamblado_facultad' ? 'selected' : '' %>>Ensamblado en Facultad</option>
          </select>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="marca" class="form-label">Marca</label>
          <input type="text" id="marca" name="marca" class="clay-input" value="<%= equipo.marca %>">
        </div>

        <div class="form-group">
          <label for="estado" class="form-label">Estado</label>
          <select id="estado" name="estado" class="clay-select" required>
            <option value="operativo" <%= equipo.estado === 'operativo' ? 'selected' : '' %>>Operativo</option>
            <option value="mantenimiento" <%= equipo.estado === 'mantenimiento' ? 'selected' : '' %>>Mantenimiento</option>
            <option value="baja" <%= equipo.estado === 'baja' ? 'selected' : '' %>>Dado de Baja</option>
          </select>
        </div>
      </div>

      <div style="margin-top: 30px; display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Guardar Cambios <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/equipos/<%= equipo.id_equipo %>" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
