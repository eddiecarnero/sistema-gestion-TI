<div class="top-bar">
  <div>
    <h1 class="page-title">Ficha Técnica: <%= equipo.codigo_inventario %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Detalles completos e historial del equipo</p>
  </div>
  <div style="display: flex; gap: 10px;">
    <a href="/equipos" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver
    </a>
    <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
      <a href="/equipos/<%= equipo.id_equipo %>/editar" class="btn btn-warning">
        <i class="fa-solid fa-pen"></i> Editar General
      </a>
    <% } %>
    <% if ((user.rol === 'administrador' || (user.rol === 'tecnico' && equipo.tipo === 'laptop')) && equipo.estado !== 'baja') { %>
      <a href="/equipos/<%= equipo.id_equipo %>/asignar" class="btn btn-success">
        <i class="fa-solid fa-user-plus"></i> Asignar Equipo
      </a>
    <% } %>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 30px;">
  
  <!-- Ficha General -->
  <div class="clay-card">
    <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px; color: var(--primary);"><i class="fa-solid fa-info-circle" style="margin-right: 8px;"></i>Datos Generales</h2>
    
    <div class="detail-grid">
      <div class="detail-item">
        <span class="detail-label">Código Inventario</span>
        <span class="detail-val" style="color: #fff; font-size: 18px;"><%= equipo.codigo_inventario %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Tipo</span>
        <span class="detail-val" style="text-transform: capitalize;"><%= equipo.tipo.replace('_', ' ') %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Origen</span>
        <span class="detail-val" style="text-transform: capitalize;"><%= equipo.tipo_origen.replace('_', ' ') %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Marca</span>
        <span class="detail-val"><%= equipo.marca || 'N/A' %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Estado</span>
        <span class="detail-val">
          <span class="badge badge-<%= equipo.estado %>"><%= equipo.estado %></span>
        </span>
      </div>
    </div>
  </div>

  <!-- Ficha de Hardware Especifico (Laptops / Componentes) -->
  <div class="clay-card">
    <% if (equipo.tipo === 'laptop') { %>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="font-size: 20px; font-weight: 800; color: var(--secondary);"><i class="fa-solid fa-laptop-code" style="margin-right: 8px;"></i>Detalles de Laptop</h2>
        <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
          <% if (equipo.laptop_serie) { %>
            <a href="/equipos/<%= equipo.id_equipo %>/laptop-detalle/editar" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px;"><i class="fa-solid fa-edit"></i> Editar</a>
          <% } else { %>
            <a href="/equipos/<%= equipo.id_equipo %>/laptop-detalle/crear" class="btn btn-primary" style="padding: 6px 12px; font-size: 12px;"><i class="fa-solid fa-plus"></i> Registrar</a>
          <% } %>
        <% } %>
      </div>

      <% if (equipo.laptop_serie) { %>
        <div class="detail-grid">
          <div class="detail-item">
            <span class="detail-label">Modelo</span>
            <span class="detail-val"><%= equipo.laptop_modelo || 'N/A' %></span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Número de Serie</span>
            <span class="detail-val" style="color: #fff;"><%= equipo.laptop_serie %></span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Procesador</span>
            <span class="detail-val" style="text-transform: capitalize;"><%= equipo.tipo_procesador %> (<%= equipo.detalle_procesador || 'N/A' %>)</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Memoria RAM</span>
            <span class="detail-val"><%= equipo.cantidad_ram %> GB <%= equipo.tipo_ram ? equipo.tipo_ram.toUpperCase() : '' %></span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Almacenamiento</span>
            <span class="detail-val"><%= equipo.cantidad_almacenamiento %> GB <%= equipo.almacenamiento ? equipo.almacenamiento.toUpperCase().replace('_', ' ') : '' %></span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Tarjeta Gráfica</span>
            <span class="detail-val" style="text-transform: capitalize;"><%= equipo.tipo_grafica %> (<%= equipo.nombre_grafica || 'N/A' %>)</span>
          </div>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-weight: 600; text-align: center; padding: 20px 0;">No se han registrado especificaciones técnicas para esta laptop.</p>
      <% } %>
    <% } else { %>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="font-size: 20px; font-weight: 800; color: var(--secondary);"><i class="fa-solid fa-microchip" style="margin-right: 8px;"></i>Componentes Internos</h2>
        <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
          <a href="/componentes/equipo/<%= equipo.id_equipo %>" class="btn btn-primary" style="padding: 6px 12px; font-size: 12px;">Gestionar Componentes</a>
        <% } %>
      </div>
      
      <% if (locals.componentes && componentes.length > 0) { %>
        <div style="display: flex; flex-direction: column; gap: 12px;">
          <% componentes.forEach(comp => { %>
            <% if (comp.estado_componente !== 'baja') { %>
              <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 18px; background-color: var(--bg-input); border-radius: 14px; border: 1px solid var(--border);">
                <div>
                  <span style="font-weight: 800; color: #fff; font-size: 14px; display: block;"><%= comp.tipo_componente %></span>
                  <span style="font-size: 13px; color: var(--text-secondary); font-weight: 600;"><%= comp.especificaciones %></span>
                </div>
                <span class="badge badge-<%= comp.estado_componente %>" style="font-size: 11px;"><%= comp.estado_componente %></span>
              </div>
            <% } %>
          <% }) %>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-weight: 600; line-height: 1.6; text-align: center; padding: 20px 0;">Este equipo no tiene componentes registrados actualmente.</p>
      <% } %>
    <% } %>
  </div>

</div>

<!-- Historial de Asignaciones -->
<div class="clay-card">
  <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px; color: var(--accent);"><i class="fa-solid fa-clock-rotate-left" style="margin-right: 8px;"></i>Historial de Asignación</h2>
  
  <div class="table-responsive" style="margin-bottom: 0;">
    <table class="clay-table">
      <thead>
        <tr>
          <th>Asignado a</th>
          <th>Ubicación / Ambiente</th>
          <th>Fecha Inicio</th>
          <th>Fecha Fin</th>
          <% if (user.rol === 'administrador' || (user.rol === 'tecnico' && equipo.tipo === 'laptop')) { %>
            <th style="text-align: right;">Acciones</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (asignaciones && asignaciones.length > 0) { %>
          <% asignaciones.forEach(asig => { %>
            <tr>
              <td>
                <% if (asig.usuario_nombres) { %>
                  <i class="fa-solid fa-user" style="margin-right: 8px; color: var(--primary);"></i>
                  <%= asig.usuario_nombres %> <%= asig.usuario_apellidos %>
                <% } else { %>
                  <span style="color: var(--text-muted);">Sin asignar a usuario</span>
                <% } %>
              </td>
              <td>
                <% if (asig.ambiente_numero) { %>
                  <i class="fa-solid fa-building" style="margin-right: 8px; color: var(--secondary);"></i>
                  <%= asig.ambiente_pabellon %> - Amb. <%= asig.ambiente_numero %>
                <% } else { %>
                  <span style="color: var(--text-muted);">Sin asignar a ambiente</span>
                <% } %>
              </td>
              <td><%= new Date(asig.fecha_inicio).toLocaleString('es-ES') %></td>
              <td>
                <% if (asig.fecha_fin) { %>
                  <%= new Date(asig.fecha_fin).toLocaleString('es-ES') %>
                <% } else { %>
                  <span class="badge badge-en_proceso">Activa</span>
                <% } %>
              </td>
              <% if (user.rol === 'administrador' || (user.rol === 'tecnico' && equipo.tipo === 'laptop')) { %>
                <td style="text-align: right;">
                  <% if (!asig.fecha_fin) { %>
                    <form action="/equipos/<%= equipo.id_equipo %>/asignacion/<%= asig.id_asignacion %>/terminar" method="POST" style="margin: 0;">
                      <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;">
                        Liberar / Terminar
                      </button>
                    </form>
                  <% } else { %>
                    -
                  <% } %>
                </td>
              <% } %>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" style="text-align: center; color: var(--text-secondary); padding: 20px 0;">Este equipo nunca ha sido asignado a un usuario o ambiente.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
