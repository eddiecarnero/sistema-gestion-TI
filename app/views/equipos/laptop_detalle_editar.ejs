<div class="top-bar">
  <div>
    <h1 class="page-title">Editar Detalles de Laptop: <%= equipo.codigo_inventario %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Actualice las especificaciones técnicas detalladas</p>
  </div>
  <div>
    <a href="/equipos/<%= id_equipo %>" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Ficha
    </a>
  </div>
</div>

<div style="max-width: 850px; margin: 0 auto;">
  <div class="clay-card">
    <% if (locals.error) { %>
      <div class="auth-error" style="margin-bottom: 25px;">
        <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/equipos/<%= id_equipo %>/laptop-detalle/editar" method="POST">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="modelo" class="form-label">Modelo Laptop</label>
          <input type="text" id="modelo" name="modelo" class="clay-input" value="<%= equipo.laptop_modelo %>" required>
        </div>

        <div class="form-group">
          <label for="serie" class="form-label">Número de Serie</label>
          <input type="text" id="serie" name="serie" class="clay-input" value="<%= equipo.laptop_serie %>" required>
        </div>
      </div>

      <h3 style="font-size: 16px; font-weight: 800; margin: 20px 0 10px 0; color: var(--primary);">Procesador</h3>
      <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px;">
        <div class="form-group">
          <label for="tipo_procesador" class="form-label">Marca Procesador</label>
          <select id="tipo_procesador" name="tipo_procesador" class="clay-select" required>
            <option value="intel" <%= equipo.tipo_procesador === 'intel' ? 'selected' : '' %>>Intel</option>
            <option value="amd" <%= equipo.tipo_procesador === 'amd' ? 'selected' : '' %>>AMD</option>
            <option value="arm" <%= equipo.tipo_procesador === 'arm' ? 'selected' : '' %>>ARM</option>
          </select>
        </div>

        <div class="form-group">
          <label for="detalle_procesador" class="form-label">Modelo / Detalle Procesador</label>
          <input type="text" id="detalle_procesador" name="detalle_procesador" class="clay-input" value="<%= equipo.detalle_procesador %>" required>
        </div>
      </div>

      <h3 style="font-size: 16px; font-weight: 800; margin: 20px 0 10px 0; color: var(--secondary);">Memoria RAM y Almacenamiento</h3>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="tipo_ram" class="form-label">Tipo de RAM</label>
          <select id="tipo_ram" name="tipo_ram" class="clay-select" required>
            <option value="ddr4" <%= equipo.tipo_ram === 'ddr4' ? 'selected' : '' %>>DDR4</option>
            <option value="ddr5" <%= equipo.tipo_ram === 'ddr5' ? 'selected' : '' %>>DDR5</option>
            <option value="ddr3" <%= equipo.tipo_ram === 'ddr3' ? 'selected' : '' %>>DDR3</option>
            <option value="ddr2" <%= equipo.tipo_ram === 'ddr2' ? 'selected' : '' %>>DDR2</option>
            <option value="ddr1" <%= equipo.tipo_ram === 'ddr1' ? 'selected' : '' %>>DDR1</option>
          </select>
        </div>

        <div class="form-group">
          <label for="cantidad_ram" class="form-label">Cantidad RAM (GB)</label>
          <input type="number" id="cantidad_ram" name="cantidad_ram" class="clay-input" min="1" value="<%= equipo.cantidad_ram %>" required>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="almacenamiento" class="form-label">Tipo de Almacenamiento</label>
          <select id="almacenamiento" name="almacenamiento" class="clay-select" required>
            <option value="ssd_nvme" <%= equipo.almacenamiento === 'ssd_nvme' ? 'selected' : '' %>>SSD NVMe</option>
            <option value="ssd_sata" <%= equipo.almacenamiento === 'ssd_sata' ? 'selected' : '' %>>SSD SATA</option>
            <option value="hdd" <%= equipo.almacenamiento === 'hdd' ? 'selected' : '' %>>HDD</option>
          </select>
        </div>

        <div class="form-group">
          <label for="cantidad_almacenamiento" class="form-label">Capacidad de Almacenamiento (GB)</label>
          <input type="number" id="cantidad_almacenamiento" name="cantidad_almacenamiento" class="clay-input" min="1" value="<%= equipo.cantidad_almacenamiento %>" required>
        </div>
      </div>

      <h3 style="font-size: 16px; font-weight: 800; margin: 20px 0 10px 0; color: var(--accent);">Gráficos</h3>
      <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px;">
        <div class="form-group">
          <label for="tipo_grafica" class="form-label">Tipo de Gráfica</label>
          <select id="tipo_grafica" name="tipo_grafica" class="clay-select" required>
            <option value="integrada" <%= equipo.tipo_grafica === 'integrada' ? 'selected' : '' %>>Integrada</option>
            <option value="dedicada" <%= equipo.tipo_grafica === 'dedicada' ? 'selected' : '' %>>Dedicada</option>
          </select>
        </div>

        <div class="form-group">
          <label for="nombre_grafica" class="form-label">Nombre / Modelo Tarjeta Gráfica</label>
          <input type="text" id="nombre_grafica" name="nombre_grafica" class="clay-input" value="<%= equipo.nombre_grafica %>" required>
        </div>
      </div>

      <div style="margin-top: 30px; display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Guardar Cambios <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/equipos/<%= id_equipo %>" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
