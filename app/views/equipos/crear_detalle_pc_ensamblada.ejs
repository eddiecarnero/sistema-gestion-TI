<div class="top-bar">
  <div>
    <h1 class="page-title">Ensamblar PC de Escritorio: <%= tempEquipo.codigo_inventario %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Seleccione los componentes de almacén para armar la(s) <%= tempEquipo.cantidad %> PC(s)</p>
  </div>
</div>

<div style="max-width: 800px; margin: 0 auto;">
  <div class="clay-card">
    
    <% if (errors && errors.length > 0) { %>
      <div class="auth-error" style="text-align: left; padding: 20px; margin-bottom: 30px;">
        <h3 style="margin-bottom: 10px; font-size: 16px;"><i class="fa-solid fa-triangle-exclamation" style="margin-right: 8px;"></i>No hay suficientes componentes en almacén:</h3>
        <ul style="padding-left: 20px; font-weight: 600; line-height: 1.6;">
          <% errors.forEach(err => { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
        <p style="margin-top: 15px; font-size: 14px; font-weight: 700; color: var(--text-secondary);">Por favor, registre nuevos componentes en el almacén primero antes de ensamblar estas PCs.</p>
        <div style="margin-top: 20px; display: flex; gap: 10px;">
          <a href="/admin/componentes/crear" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px;"><i class="fa-solid fa-plus"></i> Registrar Componentes</a>
          <a href="/equipos" class="btn btn-secondary" style="font-size: 13px; padding: 8px 16px;">Cancelar</a>
        </div>
      </div>
    <% } else { %>

      <form action="/equipos/crear/detalle-pc-ensamblada" method="POST">
        <p style="color: var(--text-secondary); margin-bottom: 25px; font-weight: 600; line-height: 1.5;">
          <i class="fa-solid fa-circle-info" style="color: var(--primary); margin-right: 8px;"></i>
          Seleccione un componente de cada tipo. Al crear la(s) <%= tempEquipo.cantidad %> PC(s), el primer equipo usará los componentes seleccionados de almacén, y los <%= tempEquipo.cantidad - 1 %> restantes se duplicarán automáticamente con copias idénticas.
        </p>

        <!-- PROCESADOR -->
        <div class="form-group">
          <label for="id_proc" class="form-label">1. Seleccionar Procesador de Almacén</label>
          <select id="id_proc" name="id_proc" class="clay-select" required>
            <option value="">-- Seleccionar Procesador --</option>
            <% disponibles.procesador.forEach(p => { %>
              <option value="<%= p.id_componente %>">#<%= p.id_componente %>: <%= p.especificaciones %></option>
            <% }) %>
          </select>
        </div>

        <!-- MEMORIA RAM -->
        <div class="form-group">
          <label for="id_ram" class="form-label">2. Seleccionar Memoria RAM de Almacenamiento</label>
          <select id="id_ram" name="id_ram" class="clay-select" required>
            <option value="">-- Seleccionar RAM --</option>
            <% disponibles.memoria_ram.forEach(r => { %>
              <option value="<%= r.id_componente %>">#<%= r.id_componente %>: <%= r.especificaciones %></option>
            <% }) %>
          </select>
        </div>

        <!-- ALMACENAMIENTO -->
        <div class="form-group">
          <label for="id_alm" class="form-label">3. Seleccionar Unidad de Almacenamiento</label>
          <select id="id_alm" name="id_alm" class="clay-select" required>
            <option value="">-- Seleccionar Almacenamiento --</option>
            <% disponibles.almacenamiento.forEach(a => { %>
              <option value="<%= a.id_componente %>">#<%= a.id_componente %>: <%= a.especificaciones %></option>
            <% }) %>
          </select>
        </div>

        <!-- PLACA MADRE -->
        <div class="form-group">
          <label for="id_mb" class="form-label">4. Seleccionar Placa Madre</label>
          <select id="id_mb" name="id_mb" class="clay-select" required>
            <option value="">-- Seleccionar Placa Madre --</option>
            <% disponibles.placa_madre.forEach(m => { %>
              <option value="<%= m.id_componente %>">#<%= m.id_componente %>: <%= m.especificaciones %></option>
            <% }) %>
          </select>
        </div>

        <!-- FUENTE DE PODER -->
        <div class="form-group" style="margin-bottom: 25px;">
          <label for="id_fp" class="form-label">5. Seleccionar Fuente de Poder</label>
          <select id="id_fp" name="id_fp" class="clay-select" required>
            <option value="">-- Seleccionar Fuente de Poder --</option>
            <% disponibles.fuente_poder.forEach(f => { %>
              <option value="<%= f.id_componente %>">#<%= f.id_componente %>: <%= f.especificaciones %></option>
            <% }) %>
          </select>
        </div>

        <!-- TARJETA GRÁFICA (Opcional) -->
        <div class="form-group" style="margin-bottom: 35px;">
          <label for="id_gpu" class="form-label">6. Seleccionar Tarjeta Gráfica (Opcional)</label>
          <select id="id_gpu" name="id_gpu" class="clay-select">
            <option value="">-- Ninguna --</option>
            <% disponibles.tarjeta_grafica.forEach(g => { %>
              <option value="<%= g.id_componente %>">#<%= g.id_componente %>: <%= g.especificaciones %></option>
            <% }) %>
          </select>
        </div>

        <div style="display: flex; gap: 15px;">
          <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
            Confirmar Ensamble y Crear PC(s) <i class="fa-solid fa-check" style="margin-left: 8px;"></i>
          </button>
          <a href="/equipos" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
        </div>
      </form>

    <% } %>

  </div>
</div>
