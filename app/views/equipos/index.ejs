<div class="top-bar">
  <div>
    <h1 class="page-title">Inventario de Equipos</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Administración general de hardware y dispositivos</p>
  </div>
  <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
    <div>
      <a href="/equipos/crear" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Registrar Equipo
      </a>
    </div>
  <% } %>
</div>

<!-- Filtros de búsqueda -->
<div class="clay-card">
  <form action="/equipos" method="GET" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 15px; align-items: flex-end;">
    <div class="form-group" style="margin-bottom: 0;">
      <label for="search" class="form-label">Buscar equipo</label>
      <input type="text" id="search" name="search" class="clay-input" placeholder="Código, marca o modelo..." value="<%= filters.search %>">
    </div>
    
    <div class="form-group" style="margin-bottom: 0;">
      <label for="tipo" class="form-label">Tipo de Equipo</label>
      <select id="tipo" name="tipo" class="clay-select">
        <option value="todos" <%= filters.tipo === 'todos' ? 'selected' : '' %>>Todos</option>
        <option value="laptop" <%= filters.tipo === 'laptop' ? 'selected' : '' %>>Laptop</option>
        <option value="pc_escritorio" <%= filters.tipo === 'pc_escritorio' ? 'selected' : '' %>>PC Escritorio</option>
        <option value="proyector" <%= filters.tipo === 'proyector' ? 'selected' : '' %>>Proyector</option>
        <option value="teclado" <%= filters.tipo === 'teclado' ? 'selected' : '' %>>Teclado</option>
        <option value="mouse" <%= filters.tipo === 'mouse' ? 'selected' : '' %>>Mouse</option>
        <option value="monitor" <%= filters.tipo === 'monitor' ? 'selected' : '' %>>Monitor</option>
        <option value="otro" <%= filters.tipo === 'otro' ? 'selected' : '' %>>Otro</option>
      </select>
    </div>

    <div class="form-group" style="margin-bottom: 0;">
      <label for="estado" class="form-label">Estado</label>
      <select id="estado" name="estado" class="clay-select">
        <option value="todos" <%= filters.estado === 'todos' ? 'selected' : '' %>>Todos</option>
        <option value="operativo" <%= filters.estado === 'operativo' ? 'selected' : '' %>>Operativo</option>
        <option value="mantenimiento" <%= filters.estado === 'mantenimiento' ? 'selected' : '' %>>Mantenimiento</option>
        <option value="baja" <%= filters.estado === 'baja' ? 'selected' : '' %>>Dado de Baja</option>
      </select>
    </div>

    <button type="submit" class="btn btn-secondary" style="height: 50px;">
      <i class="fa-solid fa-filter"></i> Filtrar
    </button>
  </form>
</div>

<!-- Tabla de equipos -->
<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>Código Inventario</th>
        <th>Tipo</th>
        <th>Marca</th>
        <th>Especificaciones</th>
        <th>Estado</th>
        <th style="text-align: right;">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (equipos && equipos.length > 0) { %>
        <% equipos.forEach(eq => { %>
          <tr>
            <td style="font-weight: 800; color: #fff;"><%= eq.codigo_inventario %></td>
            <td style="text-transform: capitalize;"><%= eq.tipo.replace('_', ' ') %></td>
            <td><%= eq.marca || 'N/A' %></td>
            <td>
              <% if (eq.tipo === 'laptop') { %>
                <span style="color: var(--text-secondary); font-size: 14px;"><%= eq.laptop_modelo || 'Sin detalles' %></span>
              <% } else { %>
                <a href="/componentes/equipo/<%= eq.id_equipo %>" style="color: var(--primary); text-decoration: none; font-size: 14px; font-weight: 700;">Ver Componentes</a>
              <% } %>
            </td>
            <td>
              <span class="badge badge-<%= eq.estado %>"><%= eq.estado %></span>
            </td>
            <td style="text-align: right; display: flex; gap: 10px; justify-content: flex-end; align-items: center;">
              <a href="/equipos/<%= eq.id_equipo %>" class="btn btn-secondary" style="padding: 8px 14px; font-size: 13px;" title="Ver Ficha Técnica">
                <i class="fa-solid fa-eye"></i>
              </a>
              <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
                <a href="/equipos/<%= eq.id_equipo %>/editar" class="btn btn-warning" style="padding: 8px 14px; font-size: 13px;" title="Editar">
                  <i class="fa-solid fa-pen"></i>
                </a>
              <% } %>
              <% if (user.rol === 'administrador' && eq.estado !== 'baja') { %>
                <form action="/equipos/<%= eq.id_equipo %>/eliminar" method="POST" onsubmit="return confirmDelete('¿Seguro que desea dar de baja este equipo?')" style="margin: 0;">
                  <button type="submit" class="btn btn-danger" style="padding: 8px 14px; font-size: 13px;" title="Dar de Baja">
                    <i class="fa-solid fa-trash-can"></i>
                  </button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="6" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No se encontraron equipos en el inventario.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
