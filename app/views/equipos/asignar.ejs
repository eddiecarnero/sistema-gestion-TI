<div class="top-bar">
  <div>
    <h1 class="page-title">Asignar Equipo: <%= equipo.codigo_inventario %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Asigne este equipo a un usuario o a un ambiente físico</p>
  </div>
  <div>
    <a href="/equipos/<%= equipo.id_equipo %>" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Ficha
    </a>
  </div>
</div>

<div style="max-width: 650px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/equipos/<%= equipo.id_equipo %>/asignar" method="POST" id="asignar-form">
      <p style="color: var(--text-secondary); margin-bottom: 25px; font-weight: 600; line-height: 1.5;">
        <i class="fa-solid fa-info-circle" style="color: var(--primary); margin-right: 8px;"></i>
        El equipo puede estar asignado a una persona responsable o a un espacio físico (como un laboratorio o una oficina). Seleccione al menos una de las dos opciones.
      </p>

      <div class="form-group">
        <label for="id_usuario" class="form-label">Asignar a Usuario (Opcional)</label>
        <select id="id_usuario" name="id_usuario" class="clay-select">
          <option value="">-- Sin Asignación de Usuario --</option>
          <% usuarios.forEach(u => { %>
            <option value="<%= u.id_usuario %>"><%= u.nombres %> <%= u.apellidos %> (<%= u.correo %>) - <%= u.cargo %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group" style="margin-bottom: 30px;">
        <label for="id_ambiente" class="form-label">Asignar a Ambiente (Opcional)</label>
        <select id="id_ambiente" name="id_ambiente" class="clay-select">
          <option value="">-- Sin Asignación de Ambiente --</option>
          <% ambientes.forEach(a => { %>
            <option value="<%= a.id_ambiente %>"><%= a.pabellon %> - Amb. <%= a.numero %> (Piso <%= a.piso %>)</option>
          <% }) %>
        </select>
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Confirmar Asignación <i class="fa-solid fa-check" style="margin-left: 8px;"></i>
        </button>
        <a href="/equipos/<%= equipo.id_equipo %>" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('asignar-form').addEventListener('submit', function(e) {
    const usuario = document.getElementById('id_usuario').value;
    const ambiente = document.getElementById('id_ambiente').value;
    if (!usuario && !ambiente) {
      e.preventDefault();
      alert('Debe seleccionar al menos un Usuario o un Ambiente para realizar la asignación.');
    }
  });
</script>
