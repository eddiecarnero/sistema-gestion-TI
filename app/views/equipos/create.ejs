<div class="top-bar">
  <div>
    <h1 class="page-title">Registrar Nuevo Equipo</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Ingrese los datos generales del dispositivo</p>
  </div>
  <div>
    <a href="/equipos" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver al Listado
    </a>
  </div>
</div>

<div style="max-width: 700px; margin: 0 auto;">
  <div class="clay-card">
    <% if (locals.error) { %>
      <div class="auth-error" style="margin-bottom: 25px;">
        <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/equipos/crear" method="POST">
      <div class="form-group">
        <label for="codigo_inventario" class="form-label">Código de Inventario</label>
        <input type="text" id="codigo_inventario" name="codigo_inventario" class="clay-input" placeholder="Ej: EQ-999" required>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="tipo" class="form-label">Tipo de Equipo</label>
          <select id="tipo" name="tipo" class="clay-select" required>
            <option value="laptop">Laptop</option>
            <option value="pc_escritorio">PC Escritorio</option>
            <option value="proyector">Proyector</option>
            <option value="teclado">Teclado</option>
            <option value="mouse">Mouse</option>
            <option value="monitor">Monitor</option>
            <option value="otro">Otro</option>
          </select>
        </div>

        <div class="form-group">
          <label for="tipo_origen" class="form-label">Origen</label>
          <select id="tipo_origen" name="tipo_origen" class="clay-select" required>
            <option value="comprado_ensamblado">Comprado Ensamblado</option>
            <option value="ensamblado_facultad">Ensamblado en Facultad</option>
          </select>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="marca" class="form-label">Marca</label>
          <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: Lenovo, HP, Dell">
        </div>

        <div class="form-group">
          <label for="estado" class="form-label">Estado Inicial</label>
          <select id="estado" name="estado" class="clay-select" required>
            <option value="operativo">Operativo</option>
            <option value="mantenimiento">Mantenimiento</option>
          </select>
        </div>
      <div class="form-group">
        <label for="cantidad" class="form-label">Cantidad a Registrar (se duplicará con sus detalles)</label>
        <input type="number" id="cantidad" name="cantidad" class="clay-input" min="1" value="1" required>
      </div>

      <div style="margin-top: 30px; display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Siguiente paso <i class="fa-solid fa-arrow-right" style="margin-left: 8px;"></i>
        </button>
        <a href="/equipos" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
