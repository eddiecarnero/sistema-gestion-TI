<div class="top-bar">
  <div>
    <h1 class="page-title">Configuración de PC Comprada: <%= tempEquipo.codigo_inventario %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Ingrese las características de los componentes que tendrá la(s) <%= tempEquipo.cantidad %> PC(s)</p>
  </div>
</div>

<div style="max-width: 900px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/equipos/crear/detalle-pc-comprada" method="POST">
      
      <!-- PROCESADOR -->
      <div style="margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
        <h3 style="font-size: 16px; font-weight: 800; color: var(--primary); margin-bottom: 15px;"><i class="fa-solid fa-microchip" style="margin-right: 8px;"></i>1. Procesador</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="proc_marca" class="form-label">Marca Procesador</label>
            <input type="text" id="proc_marca" name="proc_marca" class="clay-input" placeholder="Ej: Intel, AMD" required>
          </div>
          <div class="form-group">
            <label for="proc_modelo" class="form-label">Modelo Procesador</label>
            <input type="text" id="proc_modelo" name="proc_modelo" class="clay-input" placeholder="Ej: Core i5-12400F, Ryzen 5 5600" required>
          </div>
        </div>
      </div>

      <!-- MEMORIA RAM -->
      <div style="margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
        <h3 style="font-size: 16px; font-weight: 800; color: var(--secondary); margin-bottom: 15px;"><i class="fa-solid fa-memory" style="margin-right: 8px;"></i>2. Memoria RAM</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="ram_marca" class="form-label">Marca RAM</label>
            <input type="text" id="ram_marca" name="ram_marca" class="clay-input" placeholder="Ej: Kingston, Corsair" required>
          </div>
          <div class="form-group">
            <label for="ram_capacidad" class="form-label">Capacidad (GB)</label>
            <input type="number" id="ram_capacidad" name="ram_capacidad" class="clay-input" min="1" placeholder="Ej: 16" required>
          </div>
          <div class="form-group">
            <label for="ram_ddr" class="form-label">Tipo DDR</label>
            <select id="ram_ddr" name="ram_ddr" class="clay-select" required>
              <option value="DDR4">DDR4</option>
              <option value="DDR5">DDR5</option>
              <option value="DDR3">DDR3</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ALMACENAMIENTO -->
      <div style="margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
        <h3 style="font-size: 16px; font-weight: 800; color: var(--accent); margin-bottom: 15px;"><i class="fa-solid fa-hard-drive" style="margin-right: 8px;"></i>3. Almacenamiento</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="alm_marca" class="form-label">Marca</label>
            <input type="text" id="alm_marca" name="alm_marca" class="clay-input" placeholder="Ej: Samsung, Crucial" required>
          </div>
          <div class="form-group">
            <label for="alm_modelo" class="form-label">Modelo</label>
            <input type="text" id="alm_modelo" name="alm_modelo" class="clay-input" placeholder="Ej: 980 Pro, NV2" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="alm_tipo" class="form-label">Tipo de Disco</label>
            <select id="alm_tipo" name="alm_tipo" class="clay-select" required>
              <option value="ssd">SSD (Estado Sólido)</option>
              <option value="hdd">HDD (Disco Duro)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="alm_capacidad" class="form-label">Capacidad (GB)</label>
            <input type="number" id="alm_capacidad" name="alm_capacidad" class="clay-input" min="1" placeholder="Ej: 1000, 500" required>
          </div>
        </div>
      </div>

      <!-- PLACA MADRE -->
      <div style="margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
        <h3 style="font-size: 16px; font-weight: 800; color: var(--warning); margin-bottom: 15px;"><i class="fa-solid fa-server" style="margin-right: 8px;"></i>4. Placa Madre</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="mb_marca" class="form-label">Marca Placa</label>
            <input type="text" id="mb_marca" name="mb_marca" class="clay-input" placeholder="Ej: ASUS, Gigabyte" required>
          </div>
          <div class="form-group">
            <label for="mb_modelo" class="form-label">Modelo Placa</label>
            <input type="text" id="mb_modelo" name="mb_modelo" class="clay-input" placeholder="Ej: Prime B660M-A" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="mb_socket" class="form-label">Socket</label>
            <input type="text" id="mb_socket" name="mb_socket" class="clay-input" placeholder="Ej: LGA1700, AM4" required>
          </div>
          <div class="form-group">
            <label for="mb_factor" class="form-label">Factor de Forma</label>
            <input type="text" id="mb_factor" name="mb_factor" class="clay-input" placeholder="Ej: Micro-ATX, ATX" required>
          </div>
        </div>
      </div>

      <!-- FUENTE DE PODER -->
      <div style="margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
        <h3 style="font-size: 16px; font-weight: 800; color: #f43f5e; margin-bottom: 15px;"><i class="fa-solid fa-plug" style="margin-right: 8px;"></i>5. Fuente de Poder</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="fp_marca" class="form-label">Marca Fuente</label>
            <input type="text" id="fp_marca" name="fp_marca" class="clay-input" placeholder="Ej: EVGA, Corsair" required>
          </div>
          <div class="form-group">
            <label for="fp_modelo" class="form-label">Modelo</label>
            <input type="text" id="fp_modelo" name="fp_modelo" class="clay-input" placeholder="Ej: 600 W1" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="fp_potencia" class="form-label">Potencia (Watts)</label>
            <input type="number" id="fp_potencia" name="fp_potencia" class="clay-input" min="1" placeholder="Ej: 600" required>
          </div>
          <div class="form-group">
            <label for="fp_certificacion" class="form-label">Certificación (Opcional)</label>
            <input type="text" id="fp_certificacion" name="fp_certificacion" class="clay-input" placeholder="Ej: 80 Plus Bronze">
          </div>
        </div>
      </div>

      <!-- TARJETA GRÁFICA (Opcional) -->
      <div style="margin-bottom: 35px;">
        <h3 style="font-size: 16px; font-weight: 800; color: #06b6d4; margin-bottom: 15px;"><i class="fa-solid fa-image" style="margin-right: 8px;"></i>6. Tarjeta Gráfica (Opcional)</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="gpu_marca" class="form-label">Marca Tarjeta</label>
            <input type="text" id="gpu_marca" name="gpu_marca" class="clay-input" placeholder="Ej: ASUS, Gigabyte">
          </div>
          <div class="form-group">
            <label for="gpu_modelo" class="form-label">Modelo GPU</label>
            <input type="text" id="gpu_modelo" name="gpu_modelo" class="clay-input" placeholder="Ej: GeForce GTX 1650">
          </div>
        </div>
        <div class="form-group">
          <label for="gpu_vram" class="form-label">VRAM (GB)</label>
          <input type="number" id="gpu_vram" name="gpu_vram" class="clay-input" min="1" placeholder="Ej: 4">
        </div>
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Finalizar Registro y Crear PC(s) <i class="fa-solid fa-check" style="margin-left: 8px;"></i>
        </button>
        <a href="/equipos" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
