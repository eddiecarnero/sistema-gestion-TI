<div class="top-bar">
  <div>
    <h1 class="page-title">Gestión de Áreas y Oficinas</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Administración de las dependencias organizacionales de la facultad</p>
  </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1.2fr; gap: 30px;">
  
  <!-- Listado de Áreas -->
  <div class="table-responsive" style="margin-bottom: 0;">
    <table class="clay-table">
      <thead>
        <tr>
          <th>Área ID</th>
          <th>Nombre del Área</th>
          <th style="text-align: right;">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (areas && areas.length > 0) { %>
          <% areas.forEach(a => { %>
            <tr>
              <td>#<%= a.id_area %></td>
              <td style="font-weight: 800; color: #fff;"><%= a.nombre %></td>
              <td style="text-align: right;">
                <form action="/admin/areas/<%= a.id_area %>/eliminar" method="POST" onsubmit="return confirmDelete('¿Seguro que desea eliminar esta área? Asegúrese de que no haya usuarios asignados a ella.')" style="margin: 0;">
                  <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;">
                    <i class="fa-solid fa-trash-can"></i> Eliminar
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="3" style="text-align: center; color: var(--text-secondary); padding: 20px 0;">No hay áreas registradas.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Formulario de Creación -->
  <div class="clay-card" style="margin-bottom: 0; height: fit-content;">
    <h2 style="font-size: 18px; font-weight: 800; margin-bottom: 20px; color: var(--primary);"><i class="fa-solid fa-plus-circle" style="margin-right: 8px;"></i>Registrar Área</h2>
    
    <form action="/admin/areas/crear" method="POST">
      <div class="form-group" style="margin-bottom: 25px;">
        <label for="nombre" class="form-label">Nombre del Área / Oficina</label>
        <input type="text" id="nombre" name="nombre" class="clay-input" placeholder="Ej: Escuela de Sistemas" required>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%;">
        <i class="fa-solid fa-save"></i> Registrar
      </button>
    </form>
  </div>

</div>
