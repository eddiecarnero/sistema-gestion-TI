<div class="top-bar">
  <div>
    <h1 class="page-title">Registrar Componente en Almacén</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Ingrese las características del nuevo componente libre</p>
  </div>
  <div>
    <a href="/admin/componentes" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver al Almacén
    </a>
  </div>
</div>

<div style="max-width: 750px; margin: 0 auto;">
  <div class="clay-card">
    
    <div class="form-group" style="margin-bottom: 25px;">
      <label for="tipo_selector" class="form-label">Tipo de Componente a Registrar</label>
      <select id="tipo_selector" class="clay-select">
        <option value="procesador" <%= tipo === 'procesador' ? 'selected' : '' %>>Procesador</option>
        <option value="memoria_ram" <%= tipo === 'memoria_ram' ? 'selected' : '' %>>Memoria RAM</option>
        <option value="almacenamiento" <%= tipo === 'almacenamiento' ? 'selected' : '' %>>Almacenamiento</option>
        <option value="tarjeta_grafica" <%= tipo === 'tarjeta_grafica' ? 'selected' : '' %>>Tarjeta Gráfica</option>
        <option value="placa_madre" <%= tipo === 'placa_madre' ? 'selected' : '' %>>Placa Madre</option>
        <option value="fuente_poder" <%= tipo === 'fuente_poder' ? 'selected' : '' %>>Fuente de Poder</option>
      </select>
    </div>

    <form action="/admin/componentes/crear" method="POST">
      <!-- Pass the selected type as a hidden input -->
      <input type="hidden" name="tipo" value="<%= tipo %>">

      <!-- Procesador Fields -->
      <% if (tipo === 'procesador') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: Intel, AMD" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: Core i7 12700K" required>
          </div>
        </div>
      <% } %>

      <!-- Memoria RAM Fields -->
      <% if (tipo === 'memoria_ram') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: Kingston, Corsair" required>
          </div>
          <div class="form-group">
            <label for="capacidad_gb" class="form-label">Capacidad (GB)</label>
            <input type="number" id="capacidad_gb" name="capacidad_gb" class="clay-input" min="1" placeholder="Ej: 8, 16, 32" required>
          </div>
        </div>
        <div class="form-group">
          <label for="tipo_ddr" class="form-label">Tipo DDR</label>
          <select id="tipo_ddr" name="tipo_ddr" class="clay-select" required>
            <option value="DDR4">DDR4</option>
            <option value="DDR5">DDR5</option>
            <option value="DDR3">DDR3</option>
          </select>
        </div>
      <% } %>

      <!-- Almacenamiento Fields -->
      <% if (tipo === 'almacenamiento') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: Samsung, Kingston" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: NV2 PCIe 4.0 NVMe" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="almacenamiento_tipo" class="form-label">Tipo de Disco</label>
            <select id="almacenamiento_tipo" name="disco_tipo" class="clay-select" required>
              <option value="ssd">SSD (Estado Sólido)</option>
              <option value="hdd">HDD (Disco Duro)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="capacidad_gb" class="form-label">Capacidad (GB)</label>
            <input type="number" id="capacidad_gb" name="capacidad_gb" class="clay-input" min="1" placeholder="Ej: 240, 500, 1000" required>
          </div>
        </div>
      <% } %>

      <!-- Tarjeta Gráfica Fields -->
      <% if (tipo === 'tarjeta_grafica') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: NVIDIA, AMD" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: RTX 4060 Ti" required>
          </div>
        </div>
        <div class="form-group">
          <label for="vram_gb" class="form-label">VRAM (GB)</label>
          <input type="number" id="vram_gb" name="vram_gb" class="clay-input" min="1" placeholder="Ej: 8, 12, 16" required>
        </div>
      <% } %>

      <!-- Placa Madre Fields -->
      <% if (tipo === 'placa_madre') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: ASUS, MSI" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: MAG B650 Tomahawk" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="socket" class="form-label">Socket</label>
            <input type="text" id="socket" name="socket" class="clay-input" placeholder="Ej: AM5, LGA1700" required>
          </div>
          <div class="form-group">
            <label for="factor_forma" class="form-label">Factor de Forma</label>
            <input type="text" id="factor_forma" name="factor_forma" class="clay-input" placeholder="Ej: ATX, Micro-ATX" required>
          </div>
        </div>
      <% } %>

      <!-- Fuente de Poder Fields -->
      <% if (tipo === 'fuente_poder') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: EVGA, Seasonic" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: 750 G5" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="potencia_watts" class="form-label">Potencia (Watts)</label>
            <input type="number" id="potencia_watts" name="potencia_watts" class="clay-input" min="1" placeholder="Ej: 750" required>
          </div>
          <div class="form-group">
            <label for="certificacion" class="form-label">Certificación</label>
            <input type="text" id="certificacion" name="certificacion" class="clay-input" placeholder="Ej: 80 Plus Gold" required>
          </div>
        </div>
      <% } %>

      <div style="margin-top: 30px; display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Registrar en Almacén <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/admin/componentes" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('tipo_selector').addEventListener('change', function() {
    window.location.href = '?tipo=' + this.value;
  });
</script>
