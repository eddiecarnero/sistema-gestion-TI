<div class="top-bar">
  <div>
    <h1 class="page-title">Almacén de Componentes</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Inventario y registro central de componentes de hardware (libres y asignados)</p>
  </div>
  <div>
    <a href="/admin/componentes/crear" class="btn btn-primary">
      <i class="fa-solid fa-plus-circle"></i> Registrar Componente
    </a>
  </div>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>Componente ID</th>
        <th>Tipo</th>
        <th>Especificaciones Técnicas</th>
        <th>Estado Físico</th>
        <th>Asignación</th>
        <th style="text-align: right;">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (componentes && componentes.length > 0) { %>
        <% componentes.forEach(c => { %>
          <% if (c.estado_componente !== 'baja') { %>
            <tr>
              <td>#<%= c.id_componente %></td>
              <td style="font-weight: 800; color: #fff; text-transform: capitalize;">
                <%= c.tipo_componente.replace('_', ' ') %>
              </td>
              <td style="font-weight: 600; color: var(--text-secondary);"><%= c.especificaciones %></td>
              <td>
                <span class="badge badge-<%= c.estado_componente %>">
                  <%= c.estado_componente %>
                </span>
              </td>
              <td>
                <% if (c.id_equipo) { %>
                  <span style="font-weight: 700; color: var(--primary);">
                    <i class="fa-solid fa-desktop" style="margin-right: 5px;"></i>
                    Asignado a <a href="/equipos/<%= c.id_equipo %>" style="color: var(--primary); text-decoration: underline;"><%= c.codigo_inventario %></a>
                  </span>
                <% } else { %>
                  <span class="badge badge-pendiente" style="font-size: 11px;">
                    <i class="fa-solid fa-warehouse" style="margin-right: 5px;"></i>
                    Libre en Almacén
                  </span>
                <% } %>
              </td>
              <td style="text-align: right;">
                <a href="/componentes/<%= c.id_componente %>/editar" class="btn btn-warning" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;">
                  <i class="fa-solid fa-edit"></i> Editar
                </a>
              </td>
            </tr>
          <% } %>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="6" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No hay componentes registrados en el almacén.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
