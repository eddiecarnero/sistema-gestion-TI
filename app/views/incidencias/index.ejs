<div class="top-bar">
  <div>
    <h1 class="page-title">Mesa de Soporte / Incidencias</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Reporte y resolución de problemas técnicos</p>
  </div>
  <div>
    <a href="/incidencias/crear" class="btn btn-primary">
      <i class="fa-solid fa-plus"></i> Reportar Incidencia
    </a>
  </div>
</div>

<!-- Filtros de búsqueda (Solo para Staff) -->
<% if (user.rol === 'administrador' || user.rol === 'tecnico' || user.rol === 'practicante') { %>
  <div class="clay-card">
    <form action="/incidencias" method="GET" style="display: grid; grid-template-columns: 1fr 1fr 1.2fr 0.8fr; gap: 15px; align-items: flex-end;">
      <div class="form-group" style="margin-bottom: 0;">
        <label for="estado" class="form-label">Estado del Ticket</label>
        <select id="estado" name="estado" class="clay-select">
          <option value="todos" <%= filters.estado === 'todos' ? 'selected' : '' %>>Todos</option>
          <option value="pendiente" <%= filters.estado === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
          <option value="en_proceso" <%= filters.estado === 'en_proceso' ? 'selected' : '' %>>En Proceso</option>
          <option value="resuelta" <%= filters.estado === 'resuelta' ? 'selected' : '' %>>Resuelta</option>
          <option value="cerrada" <%= filters.estado === 'cerrada' ? 'selected' : '' %>>Cerrada</option>
          <option value="por_confirmar" <%= filters.estado === 'por_confirmar' ? 'selected' : '' %>>Por Confirmar</option>
        </select>
      </div>

      <div class="form-group" style="margin-bottom: 0;">
        <label for="prioridad" class="form-label">Prioridad</label>
        <select id="prioridad" name="prioridad" class="clay-select">
          <option value="todos" <%= filters.prioridad === 'todos' ? 'selected' : '' %>>Todas</option>
          <option value="alta" <%= filters.prioridad === 'alta' ? 'selected' : '' %>>Alta</option>
          <option value="media" <%= filters.prioridad === 'media' ? 'selected' : '' %>>Media</option>
          <option value="baja" <%= filters.prioridad === 'baja' ? 'selected' : '' %>>Baja</option>
        </select>
      </div>

      <div class="form-group" style="margin-bottom: 0;">
        <label for="id_tecnico_recibe" class="form-label">Técnico Asignado</label>
        <select id="id_tecnico_recibe" name="id_tecnico_recibe" class="clay-select">
          <option value="todos" <%= filters.id_tecnico_recibe === 'todos' ? 'selected' : '' %>>Todos</option>
          <% tecnicos.forEach(t => { %>
            <option value="<%= t.id_tecnico %>" <%= parseInt(filters.id_tecnico_recibe) === t.id_tecnico ? 'selected' : '' %>>
              <%= t.nombres %> <%= t.apellidos %> (<%= t.rango_nombre %>)
            </option>
          <% }) %>
        </select>
      </div>

      <button type="submit" class="btn btn-secondary" style="height: 50px;">
        <i class="fa-solid fa-filter"></i> Filtrar
      </button>
    </form>
  </div>
<% } %>

<!-- Tabla de incidencias -->
<div class="table-responsive">
  <table class="clay-table clay-table-compact">
    <thead>
      <tr>
        <th>Ticket ID</th>
        <th>Código Equipo</th>
        <th>Reportado por</th>
        <th>Técnico Asignado</th>
        <th>Descripción</th>
        <th>Prioridad</th>
        <th>Estado</th>
        <th>Fecha Reporte</th>
        <th style="text-align: right;">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (incidencias && incidencias.length > 0) { %>
        <% incidencias.forEach(inc => { %>
          <tr>
            <td style="font-weight: 800; color: #fff;">#<%= inc.id_incidencia %></td>
            <td><%= inc.codigo_inventario %> (<%= inc.equipo_tipo %>)</td>
            <td style="font-weight: 700;"><%= inc.reporta_nombre %></td>
            <td>
              <% if (inc.tecnico_nombres) { %>
                <span style="font-weight: 700; color: var(--secondary);"><%= inc.tecnico_nombres %> <%= inc.tecnico_apellidos %></span>
              <% } else { %>
                <span style="color: var(--danger); font-weight: 800;">SIN ASIGNAR</span>
              <% } %>
            </td>
            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= inc.descripcion %></td>
            <td>
              <span class="badge badge-prioridad-<%= inc.prioridad %>"><%= inc.prioridad %></span>
            </td>
            <td>
              <span class="badge badge-<%= inc.estado %>"><%= inc.estado.replace('_', ' ') %></span>
            </td>
            <td><%= new Date(inc.fecha_creacion).toLocaleDateString('es-ES') %></td>
            <td style="text-align: right;">
              <a href="/incidencias/<%= inc.id_incidencia %>" class="btn btn-secondary" style="padding: 8px 14px; font-size: 13px;">
                <i class="fa-solid fa-folder-open"></i> Ver Detalles
              </a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="9" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No se encontraron incidencias en esta lista.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
