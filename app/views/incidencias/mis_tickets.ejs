<div class="top-bar">
  <div>
    <h1 class="page-title">Mis Tickets Asignados</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Incidencias que tienes asignadas para resolución</p>
  </div>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>Ticket ID</th>
        <th>Código Equipo</th>
        <th>Reportado por</th>
        <th>Descripción</th>
        <th>Prioridad</th>
        <th>Estado</th>
        <th>Fecha Asignación</th>
        <th style="text-align: right;">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (incidencias && incidencias.length > 0) { %>
        <% incidencias.forEach(inc => { %>
          <tr>
            <td style="font-weight: 800; color: #fff;">#<%= inc.id_incidencia %></td>
            <td><%= inc.codigo_inventario %></td>
            <td><%= inc.usuario_nombres %> <%= inc.usuario_apellidos %></td>
            <td style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= inc.descripcion %></td>
            <td>
              <span class="badge badge-prioridad-<%= inc.prioridad %>"><%= inc.prioridad %></span>
            </td>
            <td>
              <span class="badge badge-<%= inc.estado %>"><%= inc.estado.replace('_', ' ') %></span>
            </td>
            <td><%= new Date(inc.fecha_creacion).toLocaleDateString('es-ES') %></td>
            <td style="text-align: right;">
              <a href="/incidencias/<%= inc.id_incidencia %>" class="btn btn-primary" style="padding: 8px 14px; font-size: 13px;">
                <i class="fa-solid fa-screwdriver-wrench"></i> Atender Ticket
              </a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="8" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No tienes tickets pendientes asignados en este momento.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
