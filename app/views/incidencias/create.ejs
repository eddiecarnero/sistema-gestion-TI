<div class="top-bar">
  <div>
    <h1 class="page-title">Reportar Incidencia</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Describa la falla técnica de forma detallada para su atención</p>
  </div>
  <div>
    <a href="/incidencias" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Lista
    </a>
  </div>
</div>

<div style="max-width: 700px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/incidencias/crear" method="POST">
      
      <div class="form-group">
        <label for="id_equipo" class="form-label">Seleccionar Equipo Afectado</label>
        <select id="id_equipo" name="id_equipo" class="clay-select" required>
          <% equipos.forEach(eq => { %>
            <option value="<%= eq.id_equipo %>"><%= eq.codigo_inventario %> - <%= eq.marca %> (<%= eq.tipo %>) - Estado: <%= eq.estado %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="prioridad" class="form-label">Prioridad Estimada</label>
        <select id="prioridad" name="prioridad" class="clay-select" required>
          <option value="baja">Baja (No impide el trabajo normal)</option>
          <option value="media" selected>Media (Falla parcial del dispositivo)</option>
          <option value="alta">Alta (Dispositivo inoperativo / Urgente)</option>
        </select>
      </div>

      <div class="form-group" style="margin-bottom: 30px;">
        <label for="descripcion" class="form-label">Descripción de la Falla / Incidencia</label>
        <textarea id="descripcion" name="descripcion" class="clay-textarea" placeholder="Describa qué sucede con el equipo, mensajes de error, comportamientos extraños, etc..." required></textarea>
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Enviar Ticket de Soporte <i class="fa-solid fa-paper-plane" style="margin-left: 8px;"></i>
        </button>
        <a href="/incidencias" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
