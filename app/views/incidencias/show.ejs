<div class="top-bar">
  <div>
    <h1 class="page-title">Ticket de Incidencia #<%= incidencia.id_incidencia %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Detalles e historial del caso de soporte</p>
  </div>
  <div>
    <a href="/incidencias" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Lista
    </a>
  </div>
</div>

<div style="display: grid; grid-template-columns: 3fr 2fr; gap: 30px; margin-bottom: 30px;">
  
  <!-- Detalles del Ticket -->
  <div style="display: flex; flex-direction: column; gap: 30px;">
    
    <div class="clay-card">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px; color: var(--primary);"><i class="fa-solid fa-file-invoice" style="margin-right: 8px;"></i>Datos del Ticket</h2>
      
      <div class="detail-grid" style="margin-bottom: 25px;">
        <div class="detail-item">
          <span class="detail-label">Equipo Afectado</span>
          <span class="detail-val">
            <a href="/equipos/<%= incidencia.id_equipo %>" style="color: var(--primary); text-decoration: none; font-weight: 700;">
              <%= incidencia.codigo_inventario %>
            </a>
            <span style="font-size: 13px; color: var(--text-secondary); display: block; text-transform: capitalize;"><%= incidencia.equipo_marca %> (<%= incidencia.equipo_tipo %>)</span>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">Reportado por</span>
          <span class="detail-val"><%= incidencia.reporta_nombre %></span>
        </div>
        <div class="detail-item">
          <span class="detail-label">Correo de Reportante</span>
          <span class="detail-val" style="font-size: 14px;"><%= incidencia.reporta_correo %></span>
        </div>
        <div class="detail-item">
          <span class="detail-label">Técnico Asignado</span>
          <span class="detail-val">
            <% if (incidencia.tecnico_nombres) { %>
              <i class="fa-solid fa-user-gear" style="color: var(--secondary); margin-right: 6px;"></i>
              <%= incidencia.tecnico_nombres %> <%= incidencia.tecnico_apellidos %>
            <% } else { %>
              <span style="color: var(--danger); font-weight: 800;">SIN ASIGNAR</span>
            <% } %>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">Prioridad</span>
          <span class="detail-val">
            <span class="badge badge-prioridad-<%= incidencia.prioridad %>"><%= incidencia.prioridad %></span>
          </span>
        </div>
        <div class="detail-item">
          <span class="detail-label">Estado</span>
          <span class="detail-val">
            <span class="badge badge-<%= incidencia.estado %>"><%= incidencia.estado.replace('_', ' ') %></span>
          </span>
        </div>
      </div>

      <div class="form-group">
        <span class="detail-label">Descripción del Reporte</span>
        <div style="background-color: var(--bg-input); padding: 20px; border-radius: 16px; border: 1px solid var(--border); font-size: 15px; line-height: 1.6; font-weight: 600;">
          <%= incidencia.descripcion %>
        </div>
      </div>

      <div style="display: flex; gap: 20px; margin-top: 20px; font-size: 13px; color: var(--text-secondary); font-weight: 700;">
        <span><i class="fa-solid fa-calendar" style="margin-right: 6px;"></i>Reportado: <%= new Date(incidencia.fecha_creacion).toLocaleString('es-ES') %></span>
        <% if (incidencia.fecha_resolucion) { %>
          <span style="color: var(--accent);"><i class="fa-solid fa-circle-check" style="margin-right: 6px;"></i>Resuelto: <%= new Date(incidencia.fecha_resolucion).toLocaleString('es-ES') %></span>
        <% } %>
      </div>
    </div>

    <!-- Timeline de Seguimientos -->
    <div class="clay-card">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 25px; color: var(--secondary);"><i class="fa-solid fa-route" style="margin-right: 8px;"></i>Seguimientos y Diagnósticos</h2>
      
      <% if (seguimientos && seguimientos.length > 0) { %>
        <div class="timeline">
          <% seguimientos.forEach(seg => { %>
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="clay-card timeline-card">
                <div class="timeline-header">
                  <span style="font-weight: 800; color: #fff;"><i class="fa-solid fa-user-shield" style="margin-right: 6px; color: var(--secondary);"></i><%= seg.tecnico_nombres %> <%= seg.tecnico_apellidos %></span>
                  <span><%= new Date(seg.fecha).toLocaleString('es-ES') %></span>
                </div>
                <div class="timeline-body">
                  <% if (seg.diagnostico) { %>
                    <p style="margin-bottom: 10px;"><strong>Diagnóstico:</strong> <%= seg.diagnostico %></p>
                  <% } %>
                  <% if (seg.trabajo_realizado) { %>
                    <p style="margin-bottom: 10px;"><strong>Trabajo Realizado:</strong> <%= seg.trabajo_realizado %></p>
                  <% } %>
                  <p style="font-size: 13px; color: var(--text-secondary); font-weight: 700; margin-top: 10px; display: flex; gap: 15px;">
                    <span><i class="fa-solid fa-clock" style="margin-right: 4px;"></i> Horas invertidas: <%= seg.horas_invertidas %>h</span>
                    <% if (seg.id_componente_cambiado) { %>
                      <span style="color: var(--accent);"><i class="fa-solid fa-microchip" style="margin-right: 4px;"></i> Componente cambiado: ID #<%= seg.id_componente_cambiado %></span>
                    <% } %>
                  </p>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-weight: 600; text-align: center; padding: 20px 0;">No se han registrado seguimientos para esta incidencia.</p>
      <% } %>
    </div>

  </div>

  <!-- Barra Lateral: Gestión Administrativa y Técnico -->
  <div style="display: flex; flex-direction: column; gap: 30px;">
    
    <!-- Sección de Asignación (Admin y Técnicos) -->
    <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
      <div class="clay-card">
        <h2 style="font-size: 18px; font-weight: 800; margin-bottom: 15px; color: var(--accent);"><i class="fa-solid fa-user-check" style="margin-right: 8px;"></i>Asignar Personal</h2>
        <form action="/incidencias/<%= incidencia.id_incidencia %>/asignar" method="POST">
          <div class="form-group" style="margin-bottom: 20px;">
            <label for="id_tecnico_recibe" class="form-label">Técnico / Practicante Responsable</label>
            <select id="id_tecnico_recibe" name="id_tecnico_recibe" class="clay-select" required>
              <option value="">-- Seleccionar --</option>
              <% tecnicos.forEach(tec => { %>
                <% if (user.rol === 'administrador' || tec.id_tecnico === user.id || tec.rango_nombre === 'practicante') { %>
                  <option value="<%= tec.id_tecnico %>" <%= incidencia.id_tecnico_recibe === tec.id_tecnico ? 'selected' : '' %>><%= tec.nombres %> <%= tec.apellidos %> (<%= tec.rango_nombre %>)</option>
                <% } %>
              <% }) %>
            </select>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%;">
            <i class="fa-solid fa-save"></i> Guardar Asignación
          </button>
        </form>
      </div>
    <% } %>

    <!-- Sección de Seguimiento (Técnico / Practicante asignado) -->
    <% if ((user.rol === 'tecnico' || user.rol === 'administrador' || (user.rol === 'practicante' && incidencia.estado !== 'por_confirmar')) && incidencia.estado !== 'resuelta' && incidencia.estado !== 'cerrada') { %>
      <div class="clay-card">
        <h2 style="font-size: 18px; font-weight: 800; margin-bottom: 15px; color: var(--warning);"><i class="fa-solid fa-screwdriver-wrench" style="margin-right: 8px;"></i>Registrar Seguimiento</h2>
        
        <% if (incidencia.estado === 'por_confirmar') { %>
          <div style="background-color: rgba(124, 58, 237, 0.12); border: 1px solid var(--secondary); padding: 15px; border-radius: 12px; margin-bottom: 20px; font-weight: 600; color: #fff; font-size: 14px; line-height: 1.5;">
            <i class="fa-solid fa-circle-exclamation" style="color: var(--secondary); margin-right: 8px;"></i>
            Este ticket fue pre-cerrado por un practicante y está <strong>Por Confirmar</strong>. Registre el diagnóstico final para resolver o cerrar definitivamente.
          </div>
        <% } %>

        <form action="/incidencias/<%= incidencia.id_incidencia %>/seguimiento" method="POST">
          
          <div class="form-group">
            <label for="diagnostico" class="form-label">Diagnóstico Técnico</label>
            <textarea id="diagnostico" name="diagnostico" class="clay-textarea" placeholder="Describa el diagnóstico de la falla..." required style="min-height: 80px;"></textarea>
          </div>

          <div class="form-group">
            <label for="trabajo_realizado" class="form-label">Trabajo Realizado</label>
            <textarea id="trabajo_realizado" name="trabajo_realizado" class="clay-textarea" placeholder="¿Qué reparaciones realizó?" required style="min-height: 80px;"></textarea>
          </div>

          <div class="form-group">
            <label for="horas_invertidas" class="form-label">Horas Invertidas</label>
            <input type="number" id="horas_invertidas" name="horas_invertidas" class="clay-input" min="0.5" step="0.5" placeholder="Ej: 1.5, 2.0" required>
          </div>

          <div class="form-group">
            <label for="id_componente_cambiado" class="form-label">Componente Cambiado (Opcional)</label>
            <select id="id_componente_cambiado" name="id_componente_cambiado" class="clay-select">
              <option value="">-- Ninguno --</option>
              <% componentes.forEach(comp => { %>
                <option value="<%= comp.id_componente %>"><%= comp.tipo_componente %>: <%= comp.especificaciones %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group" style="margin-bottom: 25px;">
            <label for="estado_incidencia" class="form-label">Actualizar Estado de Incidencia</label>
            <select id="estado_incidencia" name="estado_incidencia" class="clay-select" required>
              <option value="en_proceso" <%= incidencia.estado === 'en_proceso' ? 'selected' : '' %>>En Proceso</option>
              <option value="resuelta">Resuelta <%= user.rol === 'practicante' ? '(Quedará Por Confirmar)' : '(Confirmar Cierre)' %></option>
              <option value="cerrada">Cerrada <%= user.rol === 'practicante' ? '(Quedará Por Confirmar)' : '(Confirmar de Baja)' %></option>
            </select>
          </div>

          <button type="submit" class="btn btn-warning" style="width: 100%;">
            <i class="fa-solid fa-circle-check"></i> Guardar Avance / Cierre
          </button>
        </form>
      </div>
    <% } %>

  </div>

</div>
