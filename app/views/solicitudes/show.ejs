<div class="top-bar">
  <div>
    <h1 class="page-title">Solicitud #<%= solicitud.id_solicitud %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Detalles de solicitud de mejora e infraestructura</p>
  </div>
  <div>
    <a href="/solicitudes" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Lista
    </a>
  </div>
</div>

<div style="max-width: 800px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr; gap: 30px;">
  
  <!-- Detalles de la Solicitud -->
  <div class="clay-card">
    <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px; color: var(--primary);"><i class="fa-solid fa-info-circle" style="margin-right: 8px;"></i>Detalles Generales</h2>
    
    <div class="detail-grid" style="margin-bottom: 25px; grid-template-columns: 1fr;">
      <div class="detail-item">
        <span class="detail-label">Usuario Solicitante</span>
        <span class="detail-val" style="color: #fff;"><%= solicitud.usuario_nombres %> <%= solicitud.usuario_apellidos %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Correo</span>
        <span class="detail-val" style="font-size: 14px;"><%= solicitud.usuario_correo %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Área / Departamento</span>
        <span class="detail-val"><%= solicitud.area_nombre || 'N/A' %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Tipo de Solicitud</span>
        <span class="detail-val" style="text-transform: capitalize;"><%= solicitud.tipo %></span>
      </div>
    </div>

    <div class="form-group" style="margin-bottom: 25px;">
      <span class="detail-label">Descripción de la Solicitud</span>
      <div style="background-color: var(--bg-input); padding: 20px; border-radius: 16px; border: 1px solid var(--border); font-size: 15px; line-height: 1.6; font-weight: 600;">
        <%= solicitud.descripcion %>
      </div>
    </div>

    <div style="font-size: 13px; color: var(--text-secondary); font-weight: 700;">
      <span><i class="fa-solid fa-clock" style="margin-right: 6px;"></i>Registrada el: <%= new Date(solicitud.fecha_solicitud).toLocaleString('es-ES') %></span>
      <% if (solicitud.fecha_respuesta) { %>
        <div style="margin-top: 5px; color: var(--accent);">
          <i class="fa-solid fa-circle-check" style="margin-right: 6px;"></i>Respondida el: <%= new Date(solicitud.fecha_respuesta).toLocaleString('es-ES') %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Panel de Control y Estado -->
  <div style="display: flex; flex-direction: column; gap: 30px;">
    
    <div class="clay-card">
      <h2 style="font-size: 18px; font-weight: 800; margin-bottom: 15px; color: var(--secondary);"><i class="fa-solid fa-signal" style="margin-right: 8px;"></i>Estado Actual</h2>
      <div style="margin-bottom: 20px;">
        <span class="badge badge-<%= solicitud.estado === 'pendiente' ? 'pendiente' : (solicitud.estado === 'aprobada' ? 'resuelta' : 'cerrada') %>" style="font-size: 14px; padding: 8px 16px; border-radius: 14px;">
          <%= solicitud.estado.toUpperCase() %>
        </span>
      </div>

      <!-- Acciones Administrativas (Solo Admin y si está Pendiente) -->
      <% if (user.rol === 'administrador' && solicitud.estado === 'pendiente') { %>
        <h3 style="font-size: 14px; font-weight: 800; margin-bottom: 10px; color: var(--text-secondary); text-transform: uppercase;">Responder Solicitud</h3>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          <form action="/solicitudes/<%= solicitud.id_solicitud %>/responder" method="POST" style="margin: 0;">
            <input type="hidden" name="estado" value="aprobada">
            <button type="submit" class="btn btn-success" style="width: 100%;">
              <i class="fa-solid fa-circle-check"></i> Aprobar Solicitud
            </button>
          </form>
          <form action="/solicitudes/<%= solicitud.id_solicitud %>/responder" method="POST" style="margin: 0;">
            <input type="hidden" name="estado" value="rechazada">
            <button type="submit" class="btn btn-danger" style="width: 100%;">
              <i class="fa-solid fa-circle-xmark"></i> Rechazar Solicitud
            </button>
          </form>
        </div>
      <% } %>
    </div>

  </div>

</div>
