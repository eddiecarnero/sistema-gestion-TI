<div class="top-bar">
  <div>
    <h1 class="page-title">Solicitudes de Infraestructura</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Gestión de remodelaciones, mejoras y reemplazos de hardware</p>
  </div>
  <% if (user.rol === 'jefe') { %>
    <div>
      <a href="/solicitudes/crear" class="btn btn-primary">
        <i class="fa-solid fa-file-signature"></i> Nueva Solicitud
      </a>
    </div>
  <% } %>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>Solicitud ID</th>
        <th>Usuario Solicita</th>
        <th>Área</th>
        <th>Tipo</th>
        <th>Descripción</th>
        <th>Estado</th>
        <th>Fecha Registro</th>
        <th style="text-align: right;">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (solicitudes && solicitudes.length > 0) { %>
        <% solicitudes.forEach(sol => { %>
          <tr>
            <td style="font-weight: 800; color: #fff;">#<%= sol.id_solicitud %></td>
            <td><%= sol.usuario_nombres %> <%= sol.usuario_apellidos %></td>
            <td><%= sol.area_nombre || 'N/A' %></td>
            <td style="text-transform: capitalize;"><%= sol.tipo %></td>
            <td style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= sol.descripcion %></td>
            <td>
              <span class="badge badge-<%= sol.estado === 'pendiente' ? 'pendiente' : (sol.estado === 'aprobada' ? 'resuelta' : 'cerrada') %>"><%= sol.estado %></span>
            </td>
            <td><%= new Date(sol.fecha_solicitud).toLocaleDateString('es-ES') %></td>
            <td style="text-align: right;">
              <a href="/solicitudes/<%= sol.id_solicitud %>" class="btn btn-secondary" style="padding: 8px 14px; font-size: 13px;">
                <i class="fa-solid fa-folder-open"></i> Ver
              </a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="8" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No se encontraron solicitudes registradas.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
