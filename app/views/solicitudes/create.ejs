<div class="top-bar">
  <div>
    <h1 class="page-title">Nueva Solicitud de Infraestructura</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Envíe una solicitud de remodelación, mejora o reemplazo de hardware al administrador</p>
  </div>
  <div>
    <a href="/solicitudes" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Lista
    </a>
  </div>
</div>

<div style="max-width: 700px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/solicitudes/crear" method="POST">
      
      <div class="form-group">
        <label for="tipo" class="form-label">Tipo de Solicitud</label>
        <select id="tipo" name="tipo" class="clay-select" required>
          <option value="mejora" selected>Mejora de Hardware / Software</option>
          <option value="reemplazo">Reemplazo de Dispositivo Obsoleto</option>
          <option value="remodelacion">Remodelación de Ambiente Físico / Laboratorio</option>
        </select>
      </div>

      <div class="form-group" style="margin-bottom: 30px;">
        <label for="descripcion" class="form-label">Descripción Detallada de la Solicitud</label>
        <textarea id="descripcion" name="descripcion" class="clay-textarea" placeholder="Describa el motivo de la solicitud, justifique los componentes requeridos, cantidades, laboratorios y detalles correspondientes..." required></textarea>
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Enviar Solicitud <i class="fa-solid fa-paper-plane" style="margin-left: 8px;"></i>
        </button>
        <a href="/solicitudes" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
