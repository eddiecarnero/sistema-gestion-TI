<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; text-align: center; max-width: 600px; margin: 0 auto; min-height: 50vh;">
  <i class="fa-solid fa-triangle-exclamation" style="font-size: 80px; color: var(--danger); margin-bottom: 30px; filter: drop-shadow(0 0 15px rgba(239, 68, 68, 0.4));"></i>
  <h1 style="font-size: 32px; font-weight: 800; margin-bottom: 15px;">Acceso Restringido / Error</h1>
  <p style="color: var(--text-secondary); font-size: 16px; line-height: 1.6; font-weight: 600; margin-bottom: 30px;">
    <%= locals.message ? message : 'Ocurrió un error inesperado al procesar su solicitud. Comuníquese con el administrador del sistema.' %>
  </p>
  <div style="display: flex; gap: 15px; width: 100%;">
    <a href="/dashboard" class="btn btn-primary" style="flex: 1; padding: 14px;">
      <i class="fa-solid fa-house"></i> Volver al Inicio
    </a>
    <button onclick="window.history.back()" class="btn btn-secondary" style="flex: 1; padding: 14px;">
      <i class="fa-solid fa-arrow-left"></i> Regresar
    </button>
  </div>
</div>
