<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Soporte FISI</title>
  <!-- Google Fonts: Nunito -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- FontAwesome for Premium Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Stylesheets -->
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <% if (locals.user) { %>
    <!-- Sidebar Navigation -->
    <aside class="sidebar">
      <div class="app-logo">
        <div class="app-logo-icon">F</div>
        <div class="app-logo-text">Soporte FISI</div>
      </div>

      <div class="user-profile">
        <div class="user-avatar">
          <%= user.nombres.charAt(0) + user.apellidos.charAt(0) %>
        </div>
        <div class="user-info">
          <span class="user-name"><%= user.nombres %></span>
          <span class="user-role"><%= user.rol %></span>
        </div>
      </div>

      <ul class="nav-menu">
        <li>
          <a href="/dashboard" class="nav-link">
            <i class="fa-solid fa-chart-pie"></i>
            <span>Inicio</span>
          </a>
        </li>

        <% if (user.rol === 'administrador' || user.rol === 'tecnico' || user.rol === 'practicante') { %>
          <li>
            <a href="/equipos" class="nav-link">
              <i class="fa-solid fa-laptop"></i>
              <span>Equipos</span>
            </a>
          </li>
          <li>
            <a href="/software" class="nav-link">
              <i class="fa-solid fa-compact-disc"></i>
              <span>Catálogo Software</span>
            </a>
          </li>
          <li>
            <a href="/software/instalado" class="nav-link">
              <i class="fa-solid fa-download"></i>
              <span>Software Instalado</span>
            </a>
          </li>
        <% } %>

        <li>
          <a href="/incidencias" class="nav-link">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>Incidencias</span>
          </a>
        </li>

        <% if (user.rol === 'administrador' || user.rol === 'tecnico' || user.rol === 'practicante') { %>
          <li>
            <a href="/incidencias/mis-tickets" class="nav-link">
              <i class="fa-solid fa-ticket"></i>
              <span>Mis Tickets</span>
            </a>
          </li>
        <% } %>

        <% if (user.rol === 'administrador' || user.rol === 'tecnico' || user.rol === 'jefe') { %>
          <li>
            <a href="/solicitudes" class="nav-link">
              <i class="fa-solid fa-file-invoice"></i>
              <span>Solicitudes</span>
            </a>
          </li>
        <% } %>

        <% if (user.rol === 'administrador') { %>
          <li>
            <a href="/admin/usuarios" class="nav-link">
              <i class="fa-solid fa-users"></i>
              <span>Usuarios</span>
            </a>
          </li>
          <li>
            <a href="/admin/tecnicos" class="nav-link">
              <i class="fa-solid fa-user-gear"></i>
              <span>Personal Técnico</span>
            </a>
          </li>
          <li>
            <a href="/admin/areas" class="nav-link">
              <i class="fa-solid fa-building"></i>
              <span>Áreas</span>
            </a>
          </li>
          <li>
            <a href="/admin/componentes" class="nav-link">
              <i class="fa-solid fa-microchip"></i>
              <span>Almacén Componentes</span>
            </a>
          </li>
          <li>
            <a href="/admin/auditoria" class="nav-link">
              <i class="fa-solid fa-receipt"></i>
              <span>Auditoría</span>
            </a>
          </li>
          <li>
            <a href="/admin/metricas" class="nav-link">
              <i class="fa-solid fa-chart-line"></i>
              <span>Métricas</span>
            </a>
          </li>
        <% } %>

        <li>
          <a href="/auth/logout" class="nav-link nav-link-logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Cerrar Sesión</span>
          </a>
        </li>
      </ul>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
      <%- body %>
    </main>
  <% } else { %>
    <!-- Layout for unauthenticated views (e.g., login) -->
    <%- body %>
  <% } %>

  <!-- Javascript -->
  <script src="/js/main.js"></script>
  <script>
    // Keep active link styled
    const path = window.location.pathname;
    const links = document.querySelectorAll('.nav-link');
    links.forEach(link => {
      const href = link.getAttribute('href');
      if (path === href || (href !== '/dashboard' && path.startsWith(href))) {
        link.classList.add('active');
      }
    });
  </script>
</body>
</html>
