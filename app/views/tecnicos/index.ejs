<div class="top-bar">
  <div>
    <h1 class="page-title">Personal Técnico y de Soporte</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Control y asignación de técnicos y practicantes</p>
  </div>
  <div>
    <a href="/admin/tecnicos/crear" class="btn btn-primary">
      <i class="fa-solid fa-user-plus"></i> Registrar Personal
    </a>
  </div>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>Técnico ID</th>
        <th>Nombre Completo</th>
        <th>Correo Institucional</th>
        <th>Teléfono</th>
        <th>Rango (Rol Staff)</th>
        <th>Estado</th>
        <th style="text-align: right;">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (tecnicos && tecnicos.length > 0) { %>
        <% tecnicos.forEach(t => { %>
          <tr>
            <td>#<%= t.id_tecnico %></td>
            <td style="font-weight: 800; color: #fff;"><%= t.nombres %> <%= t.apellidos %></td>
            <td><%= t.correo %></td>
            <td><%= t.telefono || 'N/A' %></td>
            <td>
              <span class="badge badge-<%= t.rango_nombre === 'administrador' ? 'prioridad-alta' : (t.rango_nombre === 'tecnico' ? 'en_proceso' : 'pendiente') %>" style="font-size: 11px;">
                <%= t.rango_nombre %>
              </span>
            </td>
            <td>
              <span class="badge badge-<%= t.estado ? 'resuelta' : 'baja' %>">
                <%= t.estado ? 'Activo' : 'Inactivo' %>
              </span>
            </td>
            <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end;">
              <a href="/admin/tecnicos/<%= t.id_tecnico %>/editar" class="btn btn-warning" style="padding: 8px 14px; font-size: 13px;" title="Editar">
                <i class="fa-solid fa-user-pen"></i>
              </a>
              <% if (t.estado && t.rango_nombre !== 'administrador') { %>
                <form action="/admin/tecnicos/<%= t.id_tecnico %>/eliminar" method="POST" onsubmit="return confirmDelete('¿Seguro que desea inhabilitar a este técnico?')" style="margin: 0;">
                  <button type="submit" class="btn btn-danger" style="padding: 8px 14px; font-size: 13px;" title="Inhabilitar">
                    <i class="fa-solid fa-user-minus"></i>
                  </button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="7" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No hay personal técnico registrado.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
