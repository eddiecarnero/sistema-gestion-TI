<div class="top-bar">
  <div>
    <h1 class="page-title">Registrar Personal Técnico</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Ingrese los datos del nuevo miembro del personal de soporte</p>
  </div>
  <div>
    <a href="/admin/tecnicos" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver al Listado
    </a>
  </div>
</div>

<div style="max-width: 750px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/admin/tecnicos/crear" method="POST">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="nombres" class="form-label">Nombres</label>
          <input type="text" id="nombres" name="nombres" class="clay-input" placeholder="Ej: Luis Fernando" required>
        </div>

        <div class="form-group">
          <label for="apellidos" class="form-label">Apellidos</label>
          <input type="text" id="apellidos" name="apellidos" class="clay-input" placeholder="Ej: García Torres" required>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="correo" class="form-label">Correo Institucional</label>
          <input type="email" id="correo" name="correo" class="clay-input" placeholder="ejemplo@fisi.edu.pe" required>
        </div>

        <div class="form-group">
          <label for="telefono" class="form-label">Teléfono (Dígitos, 7-15)</label>
          <input type="text" id="telefono" name="telefono" class="clay-input" placeholder="Ej: 987654322" pattern="[0-9]{7,15}">
        </div>
      </div>

      <div class="form-group">
        <label for="id_rango" class="form-label">Rango / Nivel de Personal</label>
        <select id="id_rango" name="id_rango" class="clay-select" required>
          <% rangos.forEach(r => { %>
            <option value="<%= r.id_rango %>"><%= r.nombre %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group" style="margin-bottom: 30px;">
        <label for="contrasena" class="form-label">Contraseña Temporal</label>
        <input type="password" id="contrasena" name="contrasena" class="clay-input" placeholder="Min. 6 caracteres" required minlength="6">
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Registrar Técnico <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/admin/tecnicos" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
