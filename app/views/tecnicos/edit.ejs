<div class="top-bar">
  <div>
    <h1 class="page-title">Editar Técnico: <%= tecnico.nombres %> <%= tecnico.apellidos %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Modifique los datos, rangos o contraseñas</p>
  </div>
  <div>
    <a href="/admin/tecnicos" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver al Listado
    </a>
  </div>
</div>

<div style="max-width: 750px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/admin/tecnicos/<%= tecnico.id_tecnico %>/editar" method="POST">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="nombres" class="form-label">Nombres</label>
          <input type="text" id="nombres" name="nombres" class="clay-input" value="<%= tecnico.nombres %>" required>
        </div>

        <div class="form-group">
          <label for="apellidos" class="form-label">Apellidos</label>
          <input type="text" id="apellidos" name="apellidos" class="clay-input" value="<%= tecnico.apellidos %>" required>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="correo" class="form-label">Correo Institucional</label>
          <input type="email" id="correo" name="correo" class="clay-input" value="<%= tecnico.correo %>" required>
        </div>

        <div class="form-group">
          <label for="telefono" class="form-label">Teléfono (Dígitos, 7-15)</label>
          <input type="text" id="telefono" name="telefono" class="clay-input" value="<%= tecnico.telefono %>" pattern="[0-9]{7,15}">
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="id_rango" class="form-label">Rango Staff</label>
          <select id="id_rango" name="id_rango" class="clay-select" required>
            <% rangos.forEach(r => { %>
              <option value="<%= r.id_rango %>" <%= r.id_rango === tecnico.id_rango ? 'selected' : '' %>><%= r.nombre %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="estado" class="form-label">Estado de Cuenta</label>
          <select id="estado" name="estado" class="clay-select" required>
            <option value="1" <%= tecnico.estado ? 'selected' : '' %>>Habilitado (Activo)</option>
            <option value="0" <%= !tecnico.estado ? 'selected' : '' %>>Inhabilitado (Inactivo)</option>
          </select>
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 30px;">
        <label for="contrasena" class="form-label">Nueva Contraseña (Dejar en blanco para no cambiarla)</label>
        <input type="password" id="contrasena" name="contrasena" class="clay-input" placeholder="••••••••" minlength="6">
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Guardar Cambios <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/admin/tecnicos" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
