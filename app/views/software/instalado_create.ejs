<div class="top-bar">
  <div>
    <h1 class="page-title">Registrar Instalación de Software</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Asigne un software del catálogo a un equipo específico</p>
  </div>
  <div>
    <a href="/software/instalado" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a Instalados
    </a>
  </div>
</div>

<div style="max-width: 750px; margin: 0 auto;">
  <div class="clay-card">
    <% if (locals.error) { %>
      <div class="auth-error" style="margin-bottom: 25px;">
        <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/software/instalado/crear" method="POST">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="id_equipo" class="form-label">Equipo de Destino</label>
          <select id="id_equipo" name="id_equipo" class="clay-select" required>
            <% equipos.forEach(eq => { %>
              <option value="<%= eq.id_equipo %>"><%= eq.codigo_inventario %> - <%= eq.marca %> (<%= eq.tipo %>)</option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="id_software" class="form-label">Software a Instalar</label>
          <select id="id_software" name="id_software" class="clay-select" required>
            <% catalog.forEach(sw => { %>
              <option value="<%= sw.id_software %>"><%= sw.nombre %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 20px;">
        <div class="form-group">
          <label for="tipo_licencia" class="form-label">Tipo de Licencia</label>
          <select id="tipo_licencia" name="tipo_licencia" class="clay-select" required>
            <option value="libre">Libre (Open Source)</option>
            <option value="propietaria">Propietaria</option>
            <option value="educativa">Educativa</option>
            <option value="trial">Prueba (Trial)</option>
          </select>
        </div>

        <div class="form-group">
          <label for="clave_licencia" class="form-label">Clave de Licencia (Opcional)</label>
          <input type="text" id="clave_licencia" name="clave_licencia" class="clay-input" placeholder="Ej: XXXX-XXXX-XXXX-XXXX">
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="fecha_instalacion" class="form-label">Fecha de Instalación</label>
          <input type="date" id="fecha_instalacion" name="fecha_instalacion" class="clay-input" required value="<%= new Date().toISOString().split('T')[0] %>">
        </div>

        <div class="form-group">
          <label for="fecha_expiracion" class="form-label">Fecha de Expiración (Opcional)</label>
          <input type="date" id="fecha_expiracion" name="fecha_expiracion" class="clay-input">
        </div>
      </div>

      <div style="margin-top: 30px; display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Registrar Instalación <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/software/instalado" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
