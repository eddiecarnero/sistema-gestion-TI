<div class="top-bar">
  <div>
    <h1 class="page-title">Software Instalado</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Desglose de programas instalados en los equipos de la facultad</p>
  </div>
  <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
    <div>
      <a href="/software/instalado/crear" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Registrar Instalación
      </a>
    </div>
  <% } %>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>Equipo</th>
        <th>Software</th>
        <th>Tipo Licencia</th>
        <th>Clave Licencia</th>
        <th>Instalación</th>
        <th>Expiración</th>
        <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
          <th style="text-align: right;">Acciones</th>
        <% } %>
      </tr>
    </thead>
    <tbody>
      <% if (instaladoList && instaladoList.length > 0) { %>
        <% instaladoList.forEach(inst => { %>
          <tr>
            <td>
              <a href="/equipos/<%= inst.id_equipo %>" style="color: var(--primary); text-decoration: none; font-weight: 800;">
                <%= inst.codigo_inventario %>
              </a>
              <span style="font-size: 11px; color: var(--text-secondary); display: block; text-transform: capitalize;"><%= inst.equipo_tipo.replace('_', ' ') %></span>
            </td>
            <td style="font-weight: 700; color: #fff;"><%= inst.software_nombre %></td>
            <td style="text-transform: capitalize;"><%= inst.tipo_licencia %></td>
            <td style="font-family: monospace; font-size: 13px;"><%= inst.clave_licencia || 'N/A' %></td>
            <td><%= new Date(inst.fecha_instalacion).toLocaleDateString('es-ES') %></td>
            <td>
              <% if (inst.fecha_expiracion) { %>
                <%= new Date(inst.fecha_expiracion).toLocaleDateString('es-ES') %>
              <% } else { %>
                <span class="badge badge-resuelta" style="font-size: 11px; padding: 3px 8px;">Permanente</span>
              <% } %>
            </td>
            <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
              <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
                <a href="/software/instalado/<%= inst.id_software_instalado %>/editar" class="btn btn-warning" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;" title="Editar">
                  <i class="fa-solid fa-pen"></i>
                </a>
                <% if (user.rol === 'administrador') { %>
                  <form action="/software/instalado/<%= inst.id_software_instalado %>/eliminar" method="POST" onsubmit="return confirmDelete('¿Seguro que desea eliminar este registro de instalación?')" style="margin: 0;">
                    <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;" title="Eliminar">
                      <i class="fa-solid fa-trash-can"></i>
                    </button>
                  </form>
                <% } %>
              </td>
            <% } %>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="7" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No hay registros de software instalado en los equipos.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
