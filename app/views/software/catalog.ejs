<div class="top-bar">
  <div>
    <h1 class="page-title">Catálogo de Software</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Programas, paqueterías y licencias registradas</p>
  </div>
  <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
    <div>
      <a href="/software/crear" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Registrar Software
      </a>
    </div>
  <% } %>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Nombre del Software</th>
        <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
          <th style="text-align: right;">Acciones</th>
        <% } %>
      </tr>
    </thead>
    <tbody>
      <% if (softwareList && softwareList.length > 0) { %>
        <% softwareList.forEach(sw => { %>
          <tr>
            <td>#<%= sw.id_software %></td>
            <td style="font-weight: 800; color: #fff;"><%= sw.nombre %></td>
            <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
              <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end;">
                <a href="/software/<%= sw.id_software %>/editar" class="btn btn-warning" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;" title="Editar">
                  <i class="fa-solid fa-pen"></i>
                </a>
                <% if (user.rol === 'administrador') { %>
                  <form action="/software/<%= sw.id_software %>/eliminar" method="POST" onsubmit="return confirmDelete('¿Seguro que desea eliminar este software del catálogo?')" style="margin: 0;">
                    <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;" title="Eliminar">
                      <i class="fa-solid fa-trash-can"></i>
                    </button>
                  </form>
                <% } %>
              </td>
            <% } %>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="3" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No hay software en el catálogo.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
