<div class="top-bar">
  <div>
    <h1 class="page-title">Registrar Software en Catálogo</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Ingrese el nombre de la paquetería o software</p>
  </div>
  <div>
    <a href="/software" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver al Catálogo
    </a>
  </div>
</div>

<div style="max-width: 600px; margin: 0 auto;">
  <div class="clay-card">
    <% if (locals.error) { %>
      <div class="auth-error" style="margin-bottom: 25px;">
        <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/software/crear" method="POST">
      <div class="form-group" style="margin-bottom: 30px;">
        <label for="nombre" class="form-label">Nombre del Software</label>
        <input type="text" id="nombre" name="nombre" class="clay-input" placeholder="Ej: Windows 11 Enterprise, VS Code" required>
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Registrar Software <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/software" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
