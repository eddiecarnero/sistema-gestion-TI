<div class="top-bar">
  <div>
    <h1 class="page-title">Editar Instalación de Software</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Modifique los datos de asignación y licencia</p>
  </div>
  <div>
    <a href="/software/instalado" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a Instalados
    </a>
  </div>
</div>

<div style="max-width: 750px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/software/instalado/<%= instalado.id_software_instalado %>/editar" method="POST">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="id_equipo" class="form-label">Equipo de Destino</label>
          <select id="id_equipo" name="id_equipo" class="clay-select" required>
            <% equipos.forEach(eq => { %>
              <option value="<%= eq.id_equipo %>" <%= eq.id_equipo === instalado.id_equipo ? 'selected' : '' %>><%= eq.codigo_inventario %> - <%= eq.marca %> (<%= eq.tipo %>)</option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="id_software" class="form-label">Software Instalado</label>
          <select id="id_software" name="id_software" class="clay-select" required>
            <% catalog.forEach(sw => { %>
              <option value="<%= sw.id_software %>" <%= sw.id_software === instalado.id_software ? 'selected' : '' %>><%= sw.nombre %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 20px;">
        <div class="form-group">
          <label for="tipo_licencia" class="form-label">Tipo de Licencia</label>
          <select id="tipo_licencia" name="tipo_licencia" class="clay-select" required>
            <option value="libre" <%= instalado.tipo_licencia === 'libre' ? 'selected' : '' %>>Libre (Open Source)</option>
            <option value="propietaria" <%= instalado.tipo_licencia === 'propietaria' ? 'selected' : '' %>>Propietaria</option>
            <option value="educativa" <%= instalado.tipo_licencia === 'educativa' ? 'selected' : '' %>>Educativa</option>
            <option value="trial" <%= instalado.tipo_licencia === 'trial' ? 'selected' : '' %>>Prueba (Trial)</option>
          </select>
        </div>

        <div class="form-group">
          <label for="clave_licencia" class="form-label">Clave de Licencia (Opcional)</label>
          <input type="text" id="clave_licencia" name="clave_licencia" class="clay-input" value="<%= instalado.clave_licencia %>">
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="fecha_instalacion" class="form-label">Fecha de Instalación</label>
          <input type="date" id="fecha_instalacion" name="fecha_instalacion" class="clay-input" required value="<%= instalado.fecha_instalacion.toISOString().split('T')[0] %>">
        </div>

        <div class="form-group">
          <label for="fecha_expiracion" class="form-label">Fecha de Expiración (Opcional)</label>
          <input type="date" id="fecha_expiracion" name="fecha_expiracion" class="clay-input" value="<%= instalado.fecha_expiracion ? instalado.fecha_expiracion.toISOString().split('T')[0] : '' %>">
        </div>
      </div>

      <div style="margin-top: 30px; display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Guardar Cambios <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/software/instalado" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
