<div class="top-bar">
  <div>
    <h1 class="page-title">Gestión de Usuarios</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Control y registro de usuarios finales (Empleados y Jefes)</p>
  </div>
  <div>
    <a href="/admin/usuarios/crear" class="btn btn-primary">
      <i class="fa-solid fa-user-plus"></i> Registrar Usuario
    </a>
  </div>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>Usuario ID</th>
        <th>Nombre Completo</th>
        <th>Correo Institucional</th>
        <th>Teléfono</th>
        <th>Área</th>
        <th>Cargo (Rol)</th>
        <th>Estado</th>
        <th style="text-align: right;">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (usuarios && usuarios.length > 0) { %>
        <% usuarios.forEach(u => { %>
          <tr>
            <td>#<%= u.id_usuario %></td>
            <td style="font-weight: 800; color: #fff;"><%= u.nombres %> <%= u.apellidos %></td>
            <td><%= u.correo %></td>
            <td><%= u.telefono || 'N/A' %></td>
            <td><%= u.area_nombre %></td>
            <td>
              <span class="badge badge-<%= u.cargo === 'jefe' ? 'en_proceso' : 'cerrada' %>" style="font-size: 11px;">
                <%= u.cargo === 'jefe' ? 'Usuario Jefe' : 'Usuario Común' %>
              </span>
            </td>
            <td>
              <span class="badge badge-<%= u.estado ? 'resuelta' : 'baja' %>">
                <%= u.estado ? 'Activo' : 'Inactivo' %>
              </span>
            </td>
            <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end;">
              <a href="/admin/usuarios/<%= u.id_usuario %>/editar" class="btn btn-warning" style="padding: 8px 14px; font-size: 13px;" title="Editar">
                <i class="fa-solid fa-user-pen"></i>
              </a>
              <% if (u.estado) { %>
                <form action="/admin/usuarios/<%= u.id_usuario %>/eliminar" method="POST" onsubmit="return confirmDelete('¿Seguro que desea inhabilitar a este usuario?')" style="margin: 0;">
                  <button type="submit" class="btn btn-danger" style="padding: 8px 14px; font-size: 13px;" title="Inhabilitar">
                    <i class="fa-solid fa-user-minus"></i>
                  </button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="8" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No hay usuarios registrados.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
