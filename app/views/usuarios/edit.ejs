<div class="top-bar">
  <div>
    <h1 class="page-title">Editar Usuario: <%= user.nombres %> <%= user.apellidos %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Modifique los datos o contraseñas correspondientes</p>
  </div>
  <div>
    <a href="/admin/usuarios" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver al Listado
    </a>
  </div>
</div>

<div style="max-width: 750px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/admin/usuarios/<%= user.id_usuario %>/editar" method="POST">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="nombres" class="form-label">Nombres</label>
          <input type="text" id="nombres" name="nombres" class="clay-input" value="<%= user.nombres %>" required>
        </div>

        <div class="form-group">
          <label for="apellidos" class="form-label">Apellidos</label>
          <input type="text" id="apellidos" name="apellidos" class="clay-input" value="<%= user.apellidos %>" required>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="correo" class="form-label">Correo Institucional</label>
          <input type="email" id="correo" name="correo" class="clay-input" value="<%= user.correo %>" required>
        </div>

        <div class="form-group">
          <label for="telefono" class="form-label">Teléfono (Dígitos, 7-15)</label>
          <input type="text" id="telefono" name="telefono" class="clay-input" value="<%= user.telefono %>" pattern="[0-9]{7,15}">
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr 1.5fr; gap: 20px;">
        <div class="form-group">
          <label for="id_area" class="form-label">Área</label>
          <select id="id_area" name="id_area" class="clay-select" required>
            <% areas.forEach(a => { %>
              <option value="<%= a.id_area %>" <%= a.id_area === user.id_area ? 'selected' : '' %>><%= a.nombre %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="cargo" class="form-label">Cargo (Nivel)</label>
          <select id="cargo" name="cargo" class="clay-select" required>
            <option value="empleado" <%= user.cargo === 'empleado' ? 'selected' : '' %>>Empleado</option>
            <option value="jefe" <%= user.cargo === 'jefe' ? 'selected' : '' %>>Jefe</option>
          </select>
        </div>

        <div class="form-group">
          <label for="estado" class="form-label">Estado de Cuenta</label>
          <select id="estado" name="estado" class="clay-select" required>
            <option value="1" <%= user.estado ? 'selected' : '' %>>Habilitado (Activo)</option>
            <option value="0" <%= !user.estado ? 'selected' : '' %>>Inhabilitado (Inactivo)</option>
          </select>
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 30px;">
        <label for="contrasena" class="form-label">Nueva Contraseña (Dejar en blanco para no cambiarla)</label>
        <input type="password" id="contrasena" name="contrasena" class="clay-input" placeholder="••••••••" minlength="6">
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Guardar Cambios <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/admin/usuarios" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
