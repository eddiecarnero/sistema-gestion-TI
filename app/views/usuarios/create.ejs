<div class="top-bar">
  <div>
    <h1 class="page-title">Registrar Usuario</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Complete los datos del nuevo usuario (Jefe o Empleado)</p>
  </div>
  <div>
    <a href="/admin/usuarios" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver al Listado
    </a>
  </div>
</div>

<div style="max-width: 750px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/admin/usuarios/crear" method="POST">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="nombres" class="form-label">Nombres</label>
          <input type="text" id="nombres" name="nombres" class="clay-input" placeholder="Ej: Roberto Carlos" required>
        </div>

        <div class="form-group">
          <label for="apellidos" class="form-label">Apellidos</label>
          <input type="text" id="apellidos" name="apellidos" class="clay-input" placeholder="Ej: Sánchez Vargas" required>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="correo" class="form-label">Correo Institucional</label>
          <input type="email" id="correo" name="correo" class="clay-input" placeholder="ejemplo@fisi.edu.pe" required>
        </div>

        <div class="form-group">
          <label for="telefono" class="form-label">Teléfono (Dígitos, 7-15)</label>
          <input type="text" id="telefono" name="telefono" class="clay-input" placeholder="Ej: 987654321" pattern="[0-9]{7,15}">
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="id_area" class="form-label">Área / Oficina de Trabajo</label>
          <select id="id_area" name="id_area" class="clay-select" required>
            <% areas.forEach(a => { %>
              <option value="<%= a.id_area %>"><%= a.nombre %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="cargo" class="form-label">Cargo (Nivel de Permisos)</label>
          <select id="cargo" name="cargo" class="clay-select" required>
            <option value="empleado">Empleado (Usuario Común)</option>
            <option value="jefe">Jefe (Puede enviar solicitudes)</option>
          </select>
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 30px;">
        <label for="contrasena" class="form-label">Contraseña Temporal</label>
        <input type="password" id="contrasena" name="contrasena" class="clay-input" placeholder="Min. 6 caracteres" required minlength="6">
      </div>

      <div style="display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Registrar Usuario <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/admin/usuarios" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
