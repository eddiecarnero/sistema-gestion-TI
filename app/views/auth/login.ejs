<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Soporte FISI</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="auth-container">

  <div class="clay-card auth-card">
    <div class="auth-header">
      <div class="app-logo-icon" style="margin: 0 auto; width: 60px; height: 60px; font-size: 30px; border-radius: 20px;">F</div>
      <h1 class="auth-logo">Soporte FISI</h1>
      <p style="color: var(--text-secondary); margin-top: 10px; font-weight: 600;">Gestión de Incidencias y Hardware</p>
    </div>

    <% if (error) { %>
      <div class="auth-error">
        <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label for="correo" class="form-label">Correo Institucional</label>
        <div style="position: relative;">
          <i class="fa-solid fa-envelope" style="position: absolute; left: 20px; top: 18px; color: var(--text-secondary);"></i>
          <input type="email" id="correo" name="correo" class="clay-input" placeholder="ejemplo@fisi.edu.pe" required style="padding-left: 50px;">
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 35px;">
        <label for="contrasena" class="form-label">Contraseña</label>
        <div style="position: relative;">
          <i class="fa-solid fa-lock" style="position: absolute; left: 20px; top: 18px; color: var(--text-secondary);"></i>
          <input type="password" id="contrasena" name="contrasena" class="clay-input" placeholder="••••••••" required style="padding-left: 50px;">
        </div>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; padding: 15px; font-size: 16px;">
        Iniciar Sesión
        <i class="fa-solid fa-right-to-bracket" style="margin-left: 8px;"></i>
      </button>
    </form>
  </div>

</body>
</html>
