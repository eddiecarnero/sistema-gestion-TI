<div class="top-bar">
  <div>
    <h1 class="page-title">Asignar Componente de Almacén</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Vincule una pieza de hardware libre al equipo <%= equipo.codigo_inventario %></p>
  </div>
  <div>
    <a href="/componentes/equipo/<%= equipo.id_equipo %>" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a Componentes
    </a>
  </div>
</div>

<div style="max-width: 650px; margin: 0 auto;">
  <div class="clay-card">
    
    <% if (locals.error) { %>
      <div class="auth-error" style="margin-bottom: 25px;">
        <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/componentes/equipo/<%= equipo.id_equipo %>/asignar-almacen" method="POST">
      
      <div class="form-group" style="margin-bottom: 30px;">
        <label for="id_componente" class="form-label">Componentes Disponibles en Almacén</label>
        <select id="id_componente" name="id_componente" class="clay-select" required>
          <option value="">-- Seleccionar Componente --</option>
          <% Object.keys(disponibles).forEach(tipo => { %>
            <% if (disponibles[tipo] && disponibles[tipo].length > 0) { %>
              <optgroup label="<%= tipo.toUpperCase().replace('_', ' ') %>">
                <% disponibles[tipo].forEach(comp => { %>
                  <option value="<%= comp.id_componente %>">ID #<%= comp.id_componente %> - <%= comp.especificaciones %></option>
                <% }) %>
              </optgroup>
            <% } %>
          <% }) %>
        </select>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; padding: 14px;">
        Asignar Componente <i class="fa-solid fa-link" style="margin-left: 8px;"></i>
      </button>
    </form>

  </div>
</div>
