<div class="top-bar">
  <div>
    <h1 class="page-title">Agregar Componente: <span style="text-transform: capitalize;"><%= tipo.replace('_', ' ') %></span></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Asignar nuevo hardware a equipo <%= equipo.codigo_inventario %></p>
  </div>
  <div>
    <a href="/componentes/equipo/<%= equipo.id_equipo %>" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Lista
    </a>
  </div>
</div>

<div style="max-width: 700px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/componentes/equipo/<%= equipo.id_equipo %>/crear" method="POST">
      <input type="hidden" name="tipo" value="<%= tipo %>">

      <div class="form-group">
        <label for="estado_componente" class="form-label">Estado del Componente</label>
        <select id="estado_componente" name="estado_componente" class="clay-select" required>
          <option value="operativo">Operativo</option>
          <option value="almacenado">Almacenado</option>
          <option value="mantenimiento">Mantenimiento</option>
        </select>
      </div>

      <!-- Procesador Fields -->
      <% if (tipo === 'procesador') { %>
        <div class="form-group">
          <label for="marca" class="form-label">Marca</label>
          <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: Intel, AMD" required>
        </div>
        <div class="form-group">
          <label for="modelo" class="form-label">Modelo</label>
          <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: Core i9 13900K, Ryzen 9 7900X" required>
        </div>
      <% } %>

      <!-- RAM Fields -->
      <% if (tipo === 'memoria_ram') { %>
        <div class="form-group">
          <label for="marca" class="form-label">Marca</label>
          <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: Kingston, Corsair" required>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="capacidad_gb" class="form-label">Capacidad (GB)</label>
            <input type="number" id="capacidad_gb" name="capacidad_gb" class="clay-input" min="1" placeholder="Ej: 8, 16, 32" required>
          </div>
          <div class="form-group">
            <label for="tipo_ddr" class="form-label">Tipo DDR</label>
            <select id="tipo_ddr" name="tipo_ddr" class="clay-select" required>
              <option value="DDR4">DDR4</option>
              <option value="DDR5">DDR5</option>
              <option value="DDR3">DDR3</option>
            </select>
          </div>
        </div>
      <% } %>

      <!-- Almacenamiento Fields -->
      <% if (tipo === 'almacenamiento') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: Samsung, Kingston" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: 980 Pro, NV2" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="almacenamiento_tipo" class="form-label">Tipo de Disco</label>
            <select id="almacenamiento_tipo" name="disco_tipo" class="clay-select" required>
              <option value="ssd">SSD (Estado Sólido)</option>
              <option value="hdd">HDD (Disco Duro)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="capacidad_gb" class="form-label">Capacidad (GB)</label>
            <input type="number" id="capacidad_gb" name="capacidad_gb" class="clay-input" min="1" placeholder="Ej: 240, 500, 1000" required>
          </div>
        </div>
      <% } %>

      <!-- Tarjeta Gráfica Fields -->
      <% if (tipo === 'tarjeta_grafica') { %>
        <div class="form-group">
          <label for="marca" class="form-label">Marca</label>
          <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: ASUS, MSI, Gigabyte" required>
        </div>
        <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo GPU</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: GeForce RTX 4070, Radeon RX 7800 XT" required>
          </div>
          <div class="form-group">
            <label for="vram_gb" class="form-label">VRAM (GB)</label>
            <input type="number" id="vram_gb" name="vram_gb" class="clay-input" min="1" placeholder="Ej: 8, 12, 16" required>
          </div>
        </div>
      <% } %>

      <!-- Placa Madre Fields -->
      <% if (tipo === 'placa_madre') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: ASUS, Gigabyte" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo Placa</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: ROG Strix Z790-F" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="socket" class="form-label">Socket</label>
            <input type="text" id="socket" name="socket" class="clay-input" placeholder="Ej: LGA1700, AM5" required>
          </div>
          <div class="form-group">
            <label for="factor_forma" class="form-label">Factor Forma</label>
            <input type="text" id="factor_forma" name="factor_forma" class="clay-input" placeholder="Ej: ATX, Micro-ATX" required>
          </div>
        </div>
      <% } %>

      <!-- Fuente de Poder Fields -->
      <% if (tipo === 'fuente_poder') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" placeholder="Ej: EVGA, Corsair" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" placeholder="Ej: RM850x" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="potencia_watts" class="form-label">Potencia (Watts)</label>
            <input type="number" id="potencia_watts" name="potencia_watts" class="clay-input" min="1" placeholder="Ej: 600, 750, 850" required>
          </div>
          <div class="form-group">
            <label for="certificacion" class="form-label">Certificación (Opcional)</label>
            <input type="text" id="certificacion" name="certificacion" class="clay-input" placeholder="Ej: 80 Plus Gold, 80 Plus Bronze">
          </div>
        </div>
      <% } %>

      <div style="margin-top: 30px; display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Registrar Componente <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/componentes/equipo/<%= equipo.id_equipo %>" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
