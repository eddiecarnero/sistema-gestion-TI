<div class="top-bar">
  <div>
    <h1 class="page-title">Editar Componente: <span style="text-transform: capitalize;"><%= componente.tipo.replace('_', ' ') %></span></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Modificar hardware del equipo <%= equipo.codigo_inventario %></p>
  </div>
  <div>
    <a href="/componentes/equipo/<%= equipo.id_equipo %>" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Lista
    </a>
  </div>
</div>

<div style="max-width: 700px; margin: 0 auto;">
  <div class="clay-card">
    <form action="/componentes/<%= componente.id_componente %>/editar" method="POST">
      <input type="hidden" name="tipo" value="<%= componente.tipo %>">
      <input type="hidden" name="id_equipo" value="<%= equipo.id_equipo %>">

      <div class="form-group">
        <label for="estado_componente" class="form-label">Estado del Componente</label>
        <select id="estado_componente" name="estado_componente" class="clay-select" required>
          <option value="operativo" <%= componente.estado_componente === 'operativo' ? 'selected' : '' %>>Operativo</option>
          <option value="almacenado" <%= componente.estado_componente === 'almacenado' ? 'selected' : '' %>>Almacenado</option>
          <option value="mantenimiento" <%= componente.estado_componente === 'mantenimiento' ? 'selected' : '' %>>Mantenimiento</option>
          <option value="baja" <%= componente.estado_componente === 'baja' ? 'selected' : '' %>>Dado de Baja</option>
        </select>
      </div>

      <!-- Procesador Fields -->
      <% if (componente.tipo === 'procesador') { %>
        <div class="form-group">
          <label for="marca" class="form-label">Marca</label>
          <input type="text" id="marca" name="marca" class="clay-input" value="<%= componente.detalles.marca %>" required>
        </div>
        <div class="form-group">
          <label for="modelo" class="form-label">Modelo</label>
          <input type="text" id="modelo" name="modelo" class="clay-input" value="<%= componente.detalles.modelo %>" required>
        </div>
      <% } %>

      <!-- RAM Fields -->
      <% if (componente.tipo === 'memoria_ram') { %>
        <div class="form-group">
          <label for="marca" class="form-label">Marca</label>
          <input type="text" id="marca" name="marca" class="clay-input" value="<%= componente.detalles.marca %>" required>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="capacidad_gb" class="form-label">Capacidad (GB)</label>
            <input type="number" id="capacidad_gb" name="capacidad_gb" class="clay-input" min="1" value="<%= componente.detalles.capacidad_gb %>" required>
          </div>
          <div class="form-group">
            <label for="tipo_ddr" class="form-label">Tipo DDR</label>
            <select id="tipo_ddr" name="tipo_ddr" class="clay-select" required>
              <option value="DDR4" <%= componente.detalles.tipo_ddr === 'DDR4' ? 'selected' : '' %>>DDR4</option>
              <option value="DDR5" <%= componente.detalles.tipo_ddr === 'DDR5' ? 'selected' : '' %>>DDR5</option>
              <option value="DDR3" <%= componente.detalles.tipo_ddr === 'DDR3' ? 'selected' : '' %>>DDR3</option>
            </select>
          </div>
        </div>
      <% } %>

      <!-- Almacenamiento Fields -->
      <% if (componente.tipo === 'almacenamiento') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" value="<%= componente.detalles.marca %>" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" value="<%= componente.detalles.modelo %>" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="almacenamiento_tipo" class="form-label">Tipo de Disco</label>
            <select id="almacenamiento_tipo" name="disco_tipo" class="clay-select" required>
              <option value="ssd" <%= componente.detalles.tipo === 'ssd' ? 'selected' : '' %>>SSD (Estado Sólido)</option>
              <option value="hdd" <%= componente.detalles.tipo === 'hdd' ? 'selected' : '' %>>HDD (Disco Duro)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="capacidad_gb" class="form-label">Capacidad (GB)</label>
            <input type="number" id="capacidad_gb" name="capacidad_gb" class="clay-input" min="1" value="<%= componente.detalles.capacidad_gb %>" required>
          </div>
        </div>
      <% } %>

      <!-- Tarjeta Gráfica Fields -->
      <% if (componente.tipo === 'tarjeta_grafica') { %>
        <div class="form-group">
          <label for="marca" class="form-label">Marca</label>
          <input type="text" id="marca" name="marca" class="clay-input" value="<%= componente.detalles.marca %>" required>
        </div>
        <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo GPU</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" value="<%= componente.detalles.modelo %>" required>
          </div>
          <div class="form-group">
            <label for="vram_gb" class="form-label">VRAM (GB)</label>
            <input type="number" id="vram_gb" name="vram_gb" class="clay-input" min="1" value="<%= componente.detalles.vram_gb %>" required>
          </div>
        </div>
      <% } %>

      <!-- Placa Madre Fields -->
      <% if (componente.tipo === 'placa_madre') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" value="<%= componente.detalles.marca %>" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo Placa</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" value="<%= componente.detalles.modelo %>" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="socket" class="form-label">Socket</label>
            <input type="text" id="socket" name="socket" class="clay-input" value="<%= componente.detalles.socket %>" required>
          </div>
          <div class="form-group">
            <label for="factor_forma" class="form-label">Factor Forma</label>
            <input type="text" id="factor_forma" name="factor_forma" class="clay-input" value="<%= componente.detalles.factor_forma %>" required>
          </div>
        </div>
      <% } %>

      <!-- Fuente de Poder Fields -->
      <% if (componente.tipo === 'fuente_poder') { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="marca" class="form-label">Marca</label>
            <input type="text" id="marca" name="marca" class="clay-input" value="<%= componente.detalles.marca %>" required>
          </div>
          <div class="form-group">
            <label for="modelo" class="form-label">Modelo</label>
            <input type="text" id="modelo" name="modelo" class="clay-input" value="<%= componente.detalles.modelo %>" required>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="form-group">
            <label for="potencia_watts" class="form-label">Potencia (Watts)</label>
            <input type="number" id="potencia_watts" name="potencia_watts" class="clay-input" min="1" value="<%= componente.detalles.potencia_watts %>" required>
          </div>
          <div class="form-group">
            <label for="certificacion" class="form-label">Certificación (Opcional)</label>
            <input type="text" id="certificacion" name="certificacion" class="clay-input" value="<%= componente.detalles.certificacion %>">
          </div>
        </div>
      <% } %>

      <div style="margin-top: 30px; display: flex; gap: 15px;">
        <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">
          Guardar Cambios <i class="fa-solid fa-save" style="margin-left: 8px;"></i>
        </button>
        <a href="/componentes/equipo/<%= equipo.id_equipo %>" class="btn btn-secondary" style="flex: 1; padding: 14px;">Cancelar</a>
      </div>
    </form>
  </div>
</div>
