<div class="top-bar">
  <div>
    <h1 class="page-title">Componentes de Equipo: <%= equipo.codigo_inventario %></h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Hardware modular del equipo (<%= equipo.marca || 'N/A' %>)</p>
  </div>
  <div style="display: flex; gap: 10px;">
    <a href="/equipos/<%= equipo.id_equipo %>" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Volver a la Ficha
    </a>
    <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
      <a href="/componentes/equipo/<%= equipo.id_equipo %>/asignar-almacen" class="btn btn-secondary" style="height: 46px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; border-radius: 16px; font-size: 14px; font-weight: 700;">
        <i class="fa-solid fa-warehouse"></i> Usar Almacén
      </a>
      <div style="position: relative; display: inline-block;">
        <select id="add-component-type" class="clay-select" style="padding: 10px 40px 10px 20px; font-size: 14px; width: 220px; height: 46px;">
          <option value="procesador">Agregar Procesador</option>
          <option value="memoria_ram">Agregar Memoria RAM</option>
          <option value="almacenamiento">Agregar Almacenamiento</option>
          <option value="tarjeta_grafica">Agregar Tarjeta Video</option>
          <option value="placa_madre">Agregar Placa Madre</option>
          <option value="fuente_poder">Agregar Fuente Poder</option>
        </select>
        <button onclick="navigateCreateComponent()" class="btn btn-primary" style="position: absolute; right: 0; top: 0; border-radius: 0 16px 16px 0; height: 46px; padding: 0 15px;">
          <i class="fa-solid fa-plus"></i>
        </button>
      </div>
    <% } %>
  </div>
</div>

<div class="table-responsive">
  <table class="clay-table">
    <thead>
      <tr>
        <th>ID Componente</th>
        <th>Tipo</th>
        <th>Especificaciones</th>
        <th>Estado</th>
        <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
          <th style="text-align: right;">Acciones</th>
        <% } %>
      </tr>
    </thead>
    <tbody>
      <% if (componentes && componentes.length > 0) { %>
        <% componentes.forEach(c => { %>
          <% if (c.estado_componente !== 'baja') { %>
            <tr>
              <td>#<%= c.id_componente %></td>
              <td style="font-weight: 700; color: #fff;"><%= c.tipo_componente %></td>
              <td><%= c.especificaciones %></td>
              <td>
                <span class="badge badge-<%= c.estado_componente %>"><%= c.estado_componente %></span>
              </td>
              <% if (user.rol === 'administrador' || user.rol === 'tecnico') { %>
                <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end;">
                  <a href="/componentes/<%= c.id_componente %>/editar" class="btn btn-warning" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;" title="Editar">
                    <i class="fa-solid fa-pen"></i>
                  </a>
                  <% if (user.rol === 'administrador') { %>
                    <form action="/componentes/<%= c.id_componente %>/eliminar" method="POST" onsubmit="return confirmDelete('¿Seguro que desea dar de baja este componente?')" style="margin: 0;">
                      <input type="hidden" name="id_equipo" value="<%= equipo.id_equipo %>">
                      <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;" title="Dar de Baja">
                        <i class="fa-solid fa-trash"></i>
                      </button>
                    </form>
                  <% } %>
                </td>
              <% } %>
            </tr>
          <% } %>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="5" style="text-align: center; color: var(--text-secondary); padding: 40px 0;">No hay componentes registrados para este equipo.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<script>
  function navigateCreateComponent() {
    const type = document.getElementById('add-component-type').value;
    window.location.href = `/componentes/equipo/<%= equipo.id_equipo %>/crear?tipo=${type}`;
  }
</script>
