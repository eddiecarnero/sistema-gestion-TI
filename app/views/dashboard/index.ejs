<div class="top-bar">
  <div>
    <h1 class="page-title">Bienvenido, <%= user.nombres %>!</h1>
    <p style="color: var(--text-secondary); margin-top: 5px; font-weight: 600;">Panel de Control - Rol: <span style="color: var(--primary); text-transform: uppercase;"><%= user.rol %></span></p>
  </div>
  <div>
    <span style="color: var(--text-secondary); font-weight: 700; font-size: 14px;"><i class="fa-regular fa-calendar-days" style="margin-right: 8px;"></i><%= new Date().toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
  </div>
</div>

<% if (user.rol === 'administrador') { %>
  <!-- Grid de Métricas del Administrador -->
  <div class="stats-grid">
    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Equipos Activos</span>
        <div class="stat-icon stat-icon-blue"><i class="fa-solid fa-laptop"></i></div>
      </div>
      <div class="stat-value"><%= stats.totalEquipos %></div>
    </div>

    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Incidencias Activas</span>
        <div class="stat-icon stat-icon-amber"><i class="fa-solid fa-triangle-exclamation"></i></div>
      </div>
      <div class="stat-value"><%= stats.incidenciasPendientes %></div>
    </div>

    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Personal Técnico</span>
        <div class="stat-icon stat-icon-violet"><i class="fa-solid fa-user-gear"></i></div>
      </div>
      <div class="stat-value"><%= stats.tecnicosActivos %></div>
    </div>

    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Solicitudes</span>
        <div class="stat-icon stat-icon-emerald"><i class="fa-solid fa-file-invoice"></i></div>
      </div>
      <div class="stat-value"><%= stats.solicitudesPendientes %></div>
    </div>
  </div>

  <!-- Contenido Principal: Actividad Reciente y Accesos Rápidos -->
  <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 30px;">
    
    <div class="clay-card" style="margin-bottom: 0;">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px;"><i class="fa-solid fa-clock-rotate-left" style="margin-right: 10px; color: var(--primary);"></i>Incidencias Recientes</h2>
      <% if (stats.recientes && stats.recientes.length > 0) { %>
        <div class="table-responsive" style="margin-bottom: 0; box-shadow: none; border: none;">
          <table class="clay-table">
            <thead>
              <tr>
                <th>Usuario</th>
                <th>Prioridad</th>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody>
              <% stats.recientes.forEach(inc => { %>
                <tr>
                  <td><%= inc.nombres %> <%= inc.apellidos %></td>
                  <td>
                    <span class="badge badge-prioridad-<%= inc.prioridad %>"><%= inc.prioridad %></span>
                  </td>
                  <td>
                    <span class="badge badge-<%= inc.estado %>"><%= inc.estado.replace('_', ' ') %></span>
                  </td>
                  <td><%= new Date(inc.fecha_creacion).toLocaleDateString('es-ES') %></td>
                  <td>
                    <a href="/incidencias/<%= inc.id_incidencia %>" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;">Ver</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-weight: 600;">No hay incidencias registradas.</p>
      <% } %>
    </div>

    <div class="clay-card" style="margin-bottom: 0; display: flex; flex-direction: column; gap: 20px;">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 10px;"><i class="fa-solid fa-bolt" style="margin-right: 10px; color: var(--warning);"></i>Acciones Rápidas</h2>
      <a href="/equipos/crear" class="btn btn-primary" style="justify-content: flex-start; padding: 15px;"><i class="fa-solid fa-plus-circle"></i> Registrar Equipo</a>
      <a href="/admin/usuarios/crear" class="btn btn-secondary" style="justify-content: flex-start; padding: 15px;"><i class="fa-solid fa-user-plus"></i> Crear Usuario</a>
      <a href="/admin/tecnicos/crear" class="btn btn-secondary" style="justify-content: flex-start; padding: 15px;"><i class="fa-solid fa-user-shield"></i> Registrar Técnico</a>
      <a href="/admin/metricas" class="btn btn-success" style="justify-content: flex-start; padding: 15px;"><i class="fa-solid fa-chart-line"></i> Reportes & Métricas</a>
    </div>

  </div>

<% } else if (user.rol === 'tecnico' || user.rol === 'practicante') { %>
  <!-- Grid de Métricas del Personal Técnico -->
  <div class="stats-grid">
    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Mis Tickets Asignados</span>
        <div class="stat-icon stat-icon-blue"><i class="fa-solid fa-ticket"></i></div>
      </div>
      <div class="stat-value"><%= stats.misAsignadas %></div>
    </div>

    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Total Incidencias Pendientes</span>
        <div class="stat-icon stat-icon-amber"><i class="fa-solid fa-triangle-exclamation"></i></div>
      </div>
      <div class="stat-value"><%= stats.incidenciasPendientes %></div>
    </div>

    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Mis Tickets Resueltos</span>
        <div class="stat-icon stat-icon-emerald"><i class="fa-solid fa-circle-check"></i></div>
      </div>
      <div class="stat-value"><%= stats.misResueltas %></div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 30px;">
    
    <div class="clay-card" style="margin-bottom: 0;">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px;"><i class="fa-solid fa-list-check" style="margin-right: 10px; color: var(--primary);"></i>Mis Tareas Pendientes</h2>
      <% if (stats.tickets && stats.tickets.length > 0) { %>
        <div class="table-responsive" style="margin-bottom: 0; box-shadow: none; border: none;">
          <table class="clay-table">
            <thead>
              <tr>
                <th>Código Equipo</th>
                <th>Prioridad</th>
                <th>Fecha Reporte</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody>
              <% stats.tickets.forEach(ticket => { %>
                <tr>
                  <td><%= ticket.codigo_inventario %></td>
                  <td>
                    <span class="badge badge-prioridad-<%= ticket.prioridad %>"><%= ticket.prioridad %></span>
                  </td>
                  <td><%= new Date(ticket.fecha_creacion).toLocaleDateString('es-ES') %></td>
                  <td>
                    <a href="/incidencias/<%= ticket.id_incidencia %>" class="btn btn-primary" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;">Atender</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-weight: 600; padding: 10px;">¡Excelente! No tienes tickets pendientes asignados.</p>
      <% } %>
    </div>

    <div class="clay-card" style="margin-bottom: 0; display: flex; flex-direction: column; gap: 20px;">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 10px;"><i class="fa-solid fa-bolt" style="margin-right: 10px; color: var(--warning);"></i>Acciones Rápidas</h2>
      <a href="/incidencias/mis-tickets" class="btn btn-primary" style="justify-content: flex-start; padding: 15px;"><i class="fa-solid fa-list"></i> Ver Mis Tickets</a>
      <a href="/equipos" class="btn btn-secondary" style="justify-content: flex-start; padding: 15px;"><i class="fa-solid fa-laptop"></i> Ver Inventario de Equipos</a>
      <a href="/software" class="btn btn-secondary" style="justify-content: flex-start; padding: 15px;"><i class="fa-solid fa-compact-disc"></i> Catálogo de Software</a>
    </div>

  </div>

<% } else if (user.rol === 'jefe') { %>
  <!-- Dashboard para Usuario Jefe -->
  <div class="stats-grid" style="grid-template-columns: repeat(2, 1fr);">
    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Mis Incidencias Reportadas</span>
        <div class="stat-icon stat-icon-blue"><i class="fa-solid fa-triangle-exclamation"></i></div>
      </div>
      <div class="stat-value"><%= stats.misIncidencias %></div>
    </div>

    <div class="clay-card stat-card">
      <div class="stat-header">
        <span>Mis Solicitudes Realizadas</span>
        <div class="stat-icon stat-icon-violet"><i class="fa-solid fa-file-invoice"></i></div>
      </div>
      <div class="stat-value"><%= stats.misSolicitudes %></div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 30px;">
    
    <div class="clay-card" style="margin-bottom: 0;">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px;"><i class="fa-solid fa-clock-rotate-left" style="margin-right: 10px; color: var(--primary);"></i>Incidencias Recientes</h2>
      <% if (stats.incidencias && stats.incidencias.length > 0) { %>
        <div class="table-responsive" style="margin-bottom: 0; box-shadow: none; border: none;">
          <table class="clay-table">
            <thead>
              <tr>
                <th>Código Equipo</th>
                <th>Estado</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody>
              <% stats.incidencias.forEach(inc => { %>
                <tr>
                  <td><%= inc.codigo_inventario %></td>
                  <td>
                    <span class="badge badge-<%= inc.estado %>"><%= inc.estado.replace('_', ' ') %></span>
                  </td>
                  <td>
                    <a href="/incidencias/<%= inc.id_incidencia %>" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;">Detalle</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-weight: 600;">No has reportado incidencias recientemente.</p>
      <% } %>
    </div>

    <div class="clay-card" style="margin-bottom: 0;">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px;"><i class="fa-solid fa-file-invoice" style="margin-right: 10px; color: var(--secondary);"></i>Solicitudes Recientes</h2>
      <% if (stats.solicitudes && stats.solicitudes.length > 0) { %>
        <div class="table-responsive" style="margin-bottom: 0; box-shadow: none; border: none;">
          <table class="clay-table">
            <thead>
              <tr>
                <th>Tipo</th>
                <th>Estado</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody>
              <% stats.solicitudes.forEach(sol => { %>
                <tr>
                  <td><span style="text-transform: capitalize;"><%= sol.tipo %></span></td>
                  <td>
                    <span class="badge badge-<%= sol.estado === 'pendiente' ? 'pendiente' : (sol.estado === 'aprobada' ? 'resuelta' : 'cerrada') %>"><%= sol.estado %></span>
                  </td>
                  <td>
                    <a href="/solicitudes/<%= sol.id_solicitud %>" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;">Detalle</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-weight: 600;">No has enviado solicitudes recientemente.</p>
      <% } %>
    </div>
  </div>

  <div style="display: flex; gap: 20px;">
    <a href="/incidencias/crear" class="btn btn-primary" style="flex: 1; padding: 18px; font-size: 16px;"><i class="fa-solid fa-circle-plus" style="margin-right: 8px;"></i> Reportar Nueva Incidencia</a>
    <a href="/solicitudes/crear" class="btn btn-secondary" style="flex: 1; padding: 18px; font-size: 16px;"><i class="fa-solid fa-file-signature" style="margin-right: 8px;"></i> Enviar Nueva Solicitud (Remodelación / Mejora)</a>
  </div>

<% } else if (user.rol === 'empleado') { %>
  <!-- Dashboard para Usuario Empleado -->
  <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 30px;">
    
    <div class="clay-card" style="margin-bottom: 0;">
      <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 20px;"><i class="fa-solid fa-clock-rotate-left" style="margin-right: 10px; color: var(--primary);"></i>Mis Reportes de Incidencias</h2>
      <% if (stats.incidencias && stats.incidencias.length > 0) { %>
        <div class="table-responsive" style="margin-bottom: 0; box-shadow: none; border: none;">
          <table class="clay-table">
            <thead>
              <tr>
                <th>Código Equipo</th>
                <th>Estado</th>
                <th>Fecha Reporte</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody>
              <% stats.incidencias.forEach(inc => { %>
                <tr>
                  <td><%= inc.codigo_inventario %></td>
                  <td>
                    <span class="badge badge-<%= inc.estado %>"><%= inc.estado.replace('_', ' ') %></span>
                  </td>
                  <td><%= new Date(inc.fecha_creacion).toLocaleDateString('es-ES') %></td>
                  <td>
                    <a href="/incidencias/<%= inc.id_incidencia %>" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px; border-radius: 8px;">Ver Ticket</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-weight: 600;">No tienes incidencias registradas.</p>
      <% } %>
    </div>

    <div class="clay-card" style="margin-bottom: 0; display: flex; flex-direction: column; justify-content: center; gap: 20px; text-align: center;">
      <i class="fa-solid fa-triangle-exclamation" style="font-size: 50px; color: var(--warning); margin-bottom: 10px;"></i>
      <h3 style="font-size: 18px; font-weight: 800;">¿Tienes algún problema con un equipo?</h3>
      <p style="color: var(--text-secondary); font-weight: 600; font-size: 14px;">Reporta cualquier falla de hardware o software y nuestro personal técnico la atenderá lo antes posible.</p>
      <a href="/incidencias/crear" class="btn btn-primary" style="padding: 15px;"><i class="fa-solid fa-circle-plus"></i> Reportar Incidencia</a>
    </div>

  </div>
<% } %>
